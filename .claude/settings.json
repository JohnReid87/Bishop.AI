{
  "_comment": "Permission scope for bish-auto-card (bishop work-next). See ~/.claude/skills/bish-auto-card/SKILL.md for the canonical tool list this maps to.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bishop hook check-path"
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Bash(git push:*)",
      "Bash(sudo:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(gh:*)",
      "Bash(npm install:*)",
      "Bash(dotnet tool install:*)",
      "Bash(chmod:*)",
      "Bash(icacls:*)",
      "Bash(kill:*)",
      "Bash(taskkill:*)",
      "Bash(shutdown:*)"
    ],
    "allow": [
      "Bash(bishop:*)",
      "Bash(git:*)",
      "Bash(rm:*)",
      "Bash(Remove-Item:*)",
      "PowerShell(Remove-Item:*)",
      "Bash(dotnet build:*)",
      "Bash(dotnet test:*)",
      "Bash(dotnet restore:*)",
      "Bash(dotnet tool run:*)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Agent",
      "Bash(wc:*)",
      "Bash(xargs:*)",
      "Bash(xxd:*)",
      "PowerShell(bishop:*)",
      "Write(./.bishop/**)",
      "Read(./.bishop/**)",
      "Bash(dotnet tool run slopwatch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git rev-parse:*)"
    ]
  }
}
