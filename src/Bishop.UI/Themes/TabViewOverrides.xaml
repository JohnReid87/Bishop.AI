<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Default">
            <SolidColorBrush x:Key="TabViewItemHeaderBackground"                    Color="#1E1E1E"/>
            <SolidColorBrush x:Key="TabViewItemHeaderBackgroundPointerOver"         Color="#2A2A2A"/>
            <SolidColorBrush x:Key="TabViewItemHeaderBackgroundPressed"             Color="#2A2A2A"/>
            <SolidColorBrush x:Key="TabViewItemHeaderBackgroundSelected"            Color="#A000FF41"/>
            <SolidColorBrush x:Key="TabViewItemHeaderBackgroundSelectedPointerOver" Color="#A000FF41"/>
            <SolidColorBrush x:Key="TabViewItemHeaderBackgroundSelectedPressed"     Color="#A000FF41"/>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

</ResourceDictionary>
