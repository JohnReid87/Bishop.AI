<Application
    x:Class="Bishop.UI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Bishop.UI.Converters"
    RequestedTheme="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls"/>
                <ResourceDictionary Source="ms-appx:///Themes/Colors.xaml"/>
                <ResourceDictionary Source="ms-appx:///Themes/Brushes.xaml"/>
                <ResourceDictionary Source="ms-appx:///Resources/Icons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:BoolNegationConverter x:Key="BoolNegationConverter"/>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
            <converters:HexColorToBrushConverter x:Key="HexColorToBrushConverter"/>
            <converters:HexColorToContrastForegroundConverter x:Key="HexColorToContrastForegroundConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
