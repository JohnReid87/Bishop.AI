<ContentDialog
    x:Class="Bishop.UI.Views.CardDetailDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Bishop.UI.ViewModels"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    PrimaryButtonText="Close"
    SecondaryButtonText="Delete…"
    SecondaryButtonClick="OnSecondaryButtonClick"
    DefaultButton="Primary">
    <ContentDialog.Resources>
        <SolidColorBrush x:Key="ContentDialogBackground" Color="#14141A"/>
    </ContentDialog.Resources>
    <ContentDialog.SecondaryButtonStyle>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#FF5555"/>
        </Style>
    </ContentDialog.SecondaryButtonStyle>
    <StackPanel Spacing="12" MinWidth="400" MaxWidth="600">

        <!-- Header: #N · lane chip · skill button -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="6"
                        VerticalAlignment="Center">
                <TextBlock Text="{x:Bind ViewModel.NumberDisplay}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{StaticResource AppTextTertiaryBrush}"
                           FontFamily="Cascadia Mono"
                           VerticalAlignment="Center"/>
                <Border Background="{StaticResource AppCardBackgroundBrush}"
                        CornerRadius="3"
                        Padding="5,1">
                    <TextBlock Text="{x:Bind ViewModel.LaneName}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{StaticResource AppTextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </Border>
            </StackPanel>
            <Button Grid.Column="1"
                    Style="{StaticResource DateTimePickerFlyoutButtonStyle}"
                    ToolTipService.ToolTip="Launch skill"
                    Click="SkillButton_Click"
                    Visibility="{x:Bind ViewModel.SkillsButtonVisibility}"
                    VerticalAlignment="Center">
                <FontIcon Glyph="&#xE756;" FontSize="12"/>
            </Button>
        </Grid>

        <!-- Title -->
        <TextBlock Text="{x:Bind ViewModel.Title}"
                   Style="{StaticResource SubtitleTextBlockStyle}"
                   TextWrapping="Wrap"/>

        <!-- Description -->
        <controls:MarkdownTextBlock
            Text="{x:Bind ViewModel.Description}"
            Foreground="{StaticResource AppTextPrimaryBrush}"
            Visibility="{x:Bind ViewModel.DescriptionVisibility}"/>
        <TextBlock
            Text="No description."
            FontStyle="Italic"
            Foreground="{StaticResource AppTextTertiaryBrush}"
            Visibility="{x:Bind ViewModel.NoDescriptionVisibility}"/>

        <!-- Tags -->
        <ItemsControl
            ItemsSource="{x:Bind ViewModel.Tags}"
            Visibility="{x:Bind ViewModel.TagsVisibility}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="4"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:CardTagViewModel">
                    <Border Background="{x:Bind Colour, Converter={StaticResource HexColorToBrushConverter}}"
                            CornerRadius="3"
                            Padding="5,1">
                        <TextBlock Text="{x:Bind Name}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{x:Bind Colour, Converter={StaticResource HexColorToContrastForegroundConverter}}"
                                   VerticalAlignment="Center"/>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Delete confirmation panel -->
        <StackPanel
            Visibility="{x:Bind ViewModel.DeleteConfirmVisibility, Mode=OneWay}"
            Spacing="8">
            <TextBlock
                Text="Delete this card? This cannot be undone."
                Foreground="#FF5555"/>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button
                    Content="Yes, delete"
                    Command="{x:Bind ViewModel.ConfirmDeleteCommand}"/>
                <Button
                    Content="Cancel"
                    Command="{x:Bind ViewModel.CancelDeleteCommand}"/>
            </StackPanel>
        </StackPanel>

    </StackPanel>
</ContentDialog>
