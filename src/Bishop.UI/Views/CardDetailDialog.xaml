<ContentDialog
    x:Class="Bishop.UI.Views.CardDetailDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Bishop.UI.ViewModels"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    SecondaryButtonText="Delete…"
    SecondaryButtonClick="OnSecondaryButtonClick">
    <ContentDialog.Resources>
        <SolidColorBrush x:Key="ContentDialogBackground" Color="#14141A"/>
    </ContentDialog.Resources>
    <ContentDialog.SecondaryButtonStyle>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#FF5555"/>
        </Style>
    </ContentDialog.SecondaryButtonStyle>
    <StackPanel Spacing="12" MinWidth="400" MaxWidth="600">

        <!-- Header: #N · lane chip  |  skills  |  X close -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="6"
                        VerticalAlignment="Center">
                <TextBlock Text="{x:Bind ViewModel.NumberDisplay}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{StaticResource AppTextTertiaryBrush}"
                           FontFamily="Cascadia Mono"
                           VerticalAlignment="Center"/>
                <Border Background="{StaticResource AppCardBackgroundBrush}"
                        CornerRadius="3"
                        Padding="5,1">
                    <TextBlock Text="{x:Bind ViewModel.LaneName}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{StaticResource AppTextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </Border>
            </StackPanel>
            <Button Grid.Column="1"
                    Style="{StaticResource DateTimePickerFlyoutButtonStyle}"
                    ToolTipService.ToolTip="Launch skill"
                    Click="SkillButton_Click"
                    Visibility="{x:Bind ViewModel.SkillsButtonVisibility}"
                    VerticalAlignment="Center">
                <FontIcon Glyph="&#xE756;" FontSize="12"/>
            </Button>
            <Button Grid.Column="2"
                    Style="{StaticResource DateTimePickerFlyoutButtonStyle}"
                    ToolTipService.ToolTip="Close"
                    Click="CloseDialog_Click"
                    VerticalAlignment="Center">
                <FontIcon Glyph="&#xE8BB;" FontSize="12"/>
            </Button>
        </Grid>

        <!-- Title - view mode -->
        <TextBlock Text="{x:Bind ViewModel.Title, Mode=OneWay}"
                   Style="{StaticResource SubtitleTextBlockStyle}"
                   TextWrapping="Wrap"
                   Visibility="{x:Bind ViewModel.TitleViewVisibility, Mode=OneWay}"
                   Tapped="TitleView_Tapped"/>

        <!-- Title - edit mode -->
        <TextBox x:Name="TitleTextBox"
                 TextWrapping="Wrap"
                 Visibility="{x:Bind ViewModel.TitleEditVisibility, Mode=OneWay}"
                 LostFocus="TitleTextBox_LostFocus"
                 KeyDown="TitleTextBox_KeyDown"/>

        <!-- Description - view mode -->
        <Grid Background="Transparent"
              Visibility="{x:Bind ViewModel.DescriptionViewVisibility, Mode=OneWay}"
              Tapped="DescriptionView_Tapped">
            <controls:MarkdownTextBlock
                Text="{x:Bind ViewModel.Description, Mode=OneWay}"
                Foreground="{StaticResource AppTextPrimaryBrush}"
                Visibility="{x:Bind ViewModel.DescriptionVisibility, Mode=OneWay}"
                IsHitTestVisible="False"/>
            <TextBlock
                Text="No description."
                FontStyle="Italic"
                Foreground="{StaticResource AppTextTertiaryBrush}"
                Visibility="{x:Bind ViewModel.NoDescriptionVisibility, Mode=OneWay}"
                IsHitTestVisible="False"/>
        </Grid>

        <!-- Description - edit mode -->
        <TextBox x:Name="DescriptionTextBox"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 MinHeight="80"
                 PlaceholderText="Ctrl+Enter to save, Esc to cancel"
                 Visibility="{x:Bind ViewModel.DescriptionEditVisibility, Mode=OneWay}"
                 LostFocus="DescriptionTextBox_LostFocus"
                 KeyDown="DescriptionTextBox_KeyDown"/>

        <!-- Tags: existing chips with ×, then + to add -->
        <StackPanel Orientation="Horizontal" Spacing="4">
            <ItemsControl ItemsSource="{x:Bind ViewModel.Tags}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="4"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:CardTagViewModel">
                        <Border Background="{x:Bind Colour, Converter={StaticResource HexColorToBrushConverter}}"
                                CornerRadius="3"
                                Padding="4,1">
                            <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Name}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{x:Bind Colour, Converter={StaticResource HexColorToContrastForegroundConverter}}"
                                           VerticalAlignment="Center"/>
                                <Button Content="×"
                                        Click="RemoveTag_Click"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="1,0"
                                        MinWidth="0"
                                        MinHeight="0"
                                        FontSize="10"
                                        Foreground="{x:Bind Colour, Converter={StaticResource HexColorToContrastForegroundConverter}}"
                                        VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Button x:Name="AddTagButton"
                    Click="AddTag_Click"
                    Padding="5,1"
                    BorderThickness="0"
                    CornerRadius="3"
                    Background="{StaticResource AppDividerBrush}">
                <TextBlock Text="+"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
            </Button>
        </StackPanel>

        <!-- Inline save error -->
        <TextBlock
            Text="{x:Bind ViewModel.EditError, Mode=OneWay}"
            Foreground="#FF5555"
            TextWrapping="Wrap"
            Visibility="{x:Bind ViewModel.EditErrorVisibility, Mode=OneWay}"/>

        <!-- Delete confirmation panel -->
        <StackPanel
            Visibility="{x:Bind ViewModel.DeleteConfirmVisibility, Mode=OneWay}"
            Spacing="8">
            <TextBlock
                Text="Delete this card? This cannot be undone."
                Foreground="#FF5555"/>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button
                    Content="Yes, delete"
                    Command="{x:Bind ViewModel.ConfirmDeleteCommand}"/>
                <Button
                    Content="Cancel"
                    Command="{x:Bind ViewModel.CancelDeleteCommand}"/>
            </StackPanel>
        </StackPanel>

    </StackPanel>
</ContentDialog>
