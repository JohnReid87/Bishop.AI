<ContentDialog
    x:Class="Bishop.UI.Views.AddLaneDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Add Lane"
    PrimaryButtonText="Add"
    CloseButtonText="Cancel"
    DefaultButton="Primary">
    <ContentDialog.Resources>
        <SolidColorBrush x:Key="ContentDialogBackground" Color="#14141A"/>
    </ContentDialog.Resources>
    <StackPanel Spacing="4" MinWidth="280">
        <TextBlock Text="Name" Style="{StaticResource CaptionTextBlockStyle}"/>
        <TextBox PlaceholderText="e.g. In Progress"
                 Text="{x:Bind ViewModel.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
    </StackPanel>
</ContentDialog>
