<Page
    x:Class="Bishop.UI.Views.WorkspaceDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Bishop.UI.Views"
    xmlns:vm="using:Bishop.UI.ViewModels"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Compact header bar -->
        <Grid Grid.Row="0" Padding="16,0"
              MinHeight="48"
              BorderBrush="{StaticResource AppDividerBrush}"
              BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="1">
                <TextBlock x:Name="WorkspaceNameText"
                           Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <TextBlock x:Name="WorkspacePathText"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{StaticResource AppTextSecondaryBrush}"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <!-- Search box with custom-coloured fake placeholder -->
            <Grid Grid.Column="1" VerticalAlignment="Center" Margin="8,0" Width="150">
                <TextBox x:Name="CardSearchBox"
                         Text="{x:Bind Board.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         MinHeight="0"
                         PreviewKeyDown="CardSearch_PreviewKeyDown">
                    <TextBox.Resources>
                        <Thickness x:Key="TextControlThemePadding">10,4,10,4</Thickness>
                    </TextBox.Resources>
                </TextBox>
                <TextBlock Text="Search cards…"
                           Foreground="#44FFFFFF"
                           VerticalAlignment="Center"
                           Margin="11,0,0,0"
                           IsHitTestVisible="False"
                           Visibility="{x:Bind Board.IsSearchEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>

            <StackPanel x:Name="LaunchButtonWrapper"
                        Grid.Column="2"
                        Orientation="Horizontal"
                        Spacing="4"
                        VerticalAlignment="Center"
                        Margin="16,0,0,0">
                <Button x:Name="WorkspaceSkillsButton"
                        Padding="8,4"
                        Visibility="Collapsed"
                        Click="WorkspaceSkillsButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xEBD2;" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text="Skills" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="CommitsButton"
                        Padding="8,4"
                        Click="CommitsButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE81C;" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text="Commits" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="TerminalButton"
                        Padding="8,4"
                        Click="TerminalButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8A7;" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text="Terminal" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="ClaudeButton"
                        Padding="8,4"
                        Click="ClaudeButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE768;" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text="Claude" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="AddLaneButton"
                        Padding="8,4"
                        Click="AddLane_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE710;" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text="Lane" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="WorkspaceSettingsButton"
                        ToolTipService.ToolTip="Workspace settings"
                        Style="{StaticResource DateTimePickerFlyoutButtonStyle}"
                        Click="WorkspaceSettingsButton_Click">
                    <FontIcon Glyph="&#xE713;" FontSize="14"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Content area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left column: kanban + notes (clipped to this column when the viewer is open) -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

            <!-- Notification bars — collapsed when no InfoBar is open -->
            <StackPanel x:Name="NotificationPanel"
                        Grid.Row="0"
                        Padding="16,12,16,0"
                        Spacing="8"
                        Visibility="Collapsed">
                <InfoBar x:Name="PathWarningBar"
                         IsOpen="False"
                         IsClosable="False"
                         Severity="Warning"
                         Title="Directory not found"
                         Message="The workspace directory is missing. Right-click the workspace and choose Repath to locate it."/>
                <InfoBar x:Name="FallbackWarningBar"
                         IsOpen="False"
                         IsClosable="True"
                         Severity="Informational"
                         Title="Windows Terminal not detected"
                         Message="PowerShell opened instead — claude was not auto-started. If Windows Terminal is installed, enable its app execution alias in Settings → Apps → Advanced app settings → App execution aliases."
                         Closed="InfoBar_Closed">
                    <InfoBar.ActionButton>
                        <HyperlinkButton Content="Get Windows Terminal"
                                         NavigateUri="https://aka.ms/terminal"/>
                    </InfoBar.ActionButton>
                </InfoBar>
                <InfoBar x:Name="LaneErrorBar"
                         IsOpen="False"
                         IsClosable="True"
                         Severity="Error"
                         Closed="InfoBar_Closed"/>
                <InfoBar x:Name="CopiedBar"
                         IsOpen="False"
                         IsClosable="False"
                         Severity="Success"
                         Title="Copied to clipboard"/>
            </StackPanel>

            <!-- Kanban lanes -->
            <ScrollViewer Grid.Row="1"
                          HorizontalScrollMode="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          Padding="8,4,8,12">
                <ListView x:Name="LanesListView"
                          ItemsSource="{x:Bind Board.Lanes}"
                          SelectionMode="None"
                          AllowDrop="True"
                          DragOver="Lanes_DragOver"
                          Drop="Lanes_Drop">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsStackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,8,0"/>
                            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:LaneViewModel">
                            <Grid Width="220"
                                  VerticalAlignment="Stretch"
                                  Background="{StaticResource AppLaneBackgroundBrush}"
                                  CornerRadius="8"
                                  Padding="0,0,0,8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0"
                                      RightTapped="LaneHeader_RightTapped"
                                      CanDrag="True"
                                      DragStarting="LaneHeader_DragStarting"
                                      DropCompleted="LaneHeader_DropCompleted">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{x:Bind DisplayName, Mode=OneWay}"
                                               Style="{StaticResource BodyStrongTextBlockStyle}"
                                               Padding="12,10,12,8"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Style="{StaticResource DateTimePickerFlyoutButtonStyle}"
                                                Click="WorkNext_Click"
                                                Visibility="{x:Bind IsToDoLane, Converter={StaticResource BoolToVisibilityConverter}}"
                                                IsEnabled="{x:Bind CanPlayWorkNext, Mode=OneWay}"
                                                ToolTipService.ToolTip="{x:Bind WorkNextTooltip, Mode=OneWay}"
                                                Margin="0,0,4,0">
                                            <FontIcon Glyph="&#xE768;" FontSize="12"/>
                                        </Button>
                                        <Button Style="{StaticResource DateTimePickerFlyoutButtonStyle}"
                                                Click="WorkNextStop_Click"
                                                Visibility="{x:Bind IsToDoLane, Converter={StaticResource BoolToVisibilityConverter}}"
                                                IsEnabled="{x:Bind CanStopWorkNext, Mode=OneWay}"
                                                ToolTipService.ToolTip="{x:Bind StopWorkNextTooltip, Mode=OneWay}"
                                                Margin="0,0,4,0">
                                            <FontIcon Glyph="&#xE71A;" FontSize="12"/>
                                        </Button>
                                        <Button Style="{StaticResource DateTimePickerFlyoutButtonStyle}"
                                                Command="{x:Bind BeginAddCardCommand}"
                                                Click="BeginAddCard_Click"
                                                Margin="0,0,8,0"
                                                ToolTipService.ToolTip="Add card">
                                            <FontIcon Glyph="&#xE710;" FontSize="12"/>
                                        </Button>
                                    </StackPanel>
                                    <FlyoutBase.AttachedFlyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem Text="Rename" Click="RenameLane_Click">
                                                <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8AC;"/></MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            <MenuFlyoutSeparator/>
                                            <MenuFlyoutItem Text="Delete" Click="DeleteLane_Click">
                                                <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74D;"/></MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                        </MenuFlyout>
                                    </FlyoutBase.AttachedFlyout>
                                </Grid>

                                <ListView Grid.Row="1"
                                          ItemsSource="{x:Bind FilteredCards}"
                                          SelectionMode="None"
                                          AllowDrop="True"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          DragOver="Cards_DragOver"
                                          DragLeave="Cards_DragLeave"
                                          Drop="Cards_Drop">
                                    <ListView.Header>
                                        <StackPanel Spacing="4"
                                                    Margin="8,4,8,4"
                                                    Visibility="{x:Bind IsAddingCard, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBox PlaceholderText="Card title"
                                                     Text="{x:Bind NewCardTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     PreviewKeyDown="AddCardTextBox_PreviewKeyDown"/>
                                            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right">
                                                <Button Content="&#x2713;"
                                                        Command="{x:Bind ConfirmAddCardCommand}"
                                                        ToolTipService.ToolTip="Add card (Enter)"/>
                                                <Button Content="&#x2715;"
                                                        Command="{x:Bind CancelAddCardCommand}"
                                                        ToolTipService.ToolTip="Cancel (Escape)"/>
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind AddCardErrorMessage, Mode=OneWay}"
                                                       Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                                       TextWrapping="Wrap"
                                                       FontSize="12"
                                                       Visibility="{x:Bind HasAddCardError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        </StackPanel>
                                    </ListView.Header>
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="vm:CardViewModel">
                                            <Grid Margin="8,0,8,4"
                                                  Opacity="{x:Bind CardOpacity}">
                                                <Border Background="{StaticResource AppCardBackgroundBrush}"
                                                        CornerRadius="4">
                                                <StackPanel>
                                                    <!-- Card header: drag handle -->
                                                    <local:HandCursorGrid Padding="{x:Bind CardHeaderPadding}"
                                                                          Background="Transparent"
                                                                          BorderBrush="{StaticResource AppDividerBrush}"
                                                                          BorderThickness="0,0,0,1"
                                                                          CanDrag="True"
                                                                          DragStarting="Card_DragStarting"
                                                                          DropCompleted="Card_DropCompleted">
                                                        <local:HandCursorGrid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </local:HandCursorGrid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0"
                                                                    Orientation="Horizontal"
                                                                    Spacing="6"
                                                                    VerticalAlignment="Center">
                                                            <TextBlock Text="{x:Bind NumberDisplay}"
                                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                                       Foreground="{StaticResource AppTextTertiaryBrush}"
                                                                       FontFamily="Cascadia Mono"
                                                                       VerticalAlignment="Center"/>
                                                            <Border Background="{x:Bind FirstTagColour, Converter={StaticResource HexColorToBrushConverter}}"
                                                                    CornerRadius="3"
                                                                    Padding="5,1"
                                                                    Visibility="{x:Bind TagChipVisibility}">
                                                                <TextBlock Text="{x:Bind FirstTagName}"
                                                                           Style="{StaticResource CaptionTextBlockStyle}"
                                                                           Foreground="{x:Bind FirstTagColour, Converter={StaticResource HexColorToContrastForegroundConverter}}"
                                                                           VerticalAlignment="Center"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1"
                                                                    Orientation="Horizontal">
                                                            <Button Style="{StaticResource DateTimePickerFlyoutButtonStyle}"
                                                                    ToolTipService.ToolTip="Skills"
                                                                    Click="CardSkillsButton_Click"
                                                                    Visibility="{x:Bind SkillsButtonVisibility}"
                                                                    VerticalAlignment="Center">
                                                                <FontIcon Glyph="&#xEBD2;" FontSize="12"/>
                                                            </Button>
                                                            <Button Style="{StaticResource DateTimePickerFlyoutButtonStyle}"
                                                                    ToolTipService.ToolTip="{x:Bind CloseReopenTooltip}"
                                                                    Click="CardCloseButton_Click"
                                                                    VerticalAlignment="Center">
                                                                <FontIcon Glyph="{x:Bind CloseReopenGlyph}" FontSize="12"/>
                                                            </Button>
                                                        </StackPanel>
                                                    </local:HandCursorGrid>
                                                    <!-- Card title: tap to open detail -->
                                                    <TextBlock Text="{x:Bind Title}"
                                                               TextWrapping="Wrap"
                                                               Padding="{x:Bind CardTitlePadding}"
                                                               FontSize="{x:Bind CardTitleFontSize}"
                                                               Tapped="CardTitle_Tapped"/>
                                                </StackPanel>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>


<!-- Drag-target highlight overlay -->
                                <Border Grid.RowSpan="2"
                                        IsHitTestVisible="False"
                                        CornerRadius="8"
                                        BorderBrush="{StaticResource AppDragTargetBorderBrush}"
                                        BorderThickness="2"
                                        Background="{StaticResource AppDragTargetBrush}"
                                        Visibility="{x:Bind IsDropTarget, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </ScrollViewer>

            <!-- Notes splitter -->
            <local:NotesSplitter Grid.Row="2"
                                 Height="6"
                                 Background="{StaticResource AppDividerBrush}"
                                 Visibility="{x:Bind Notes.IsExpanded, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                 PointerPressed="NotesSplitter_PointerPressed"
                                 PointerMoved="NotesSplitter_PointerMoved"
                                 PointerReleased="NotesSplitter_PointerReleased"
                                 PointerCaptureLost="NotesSplitter_PointerCaptureLost"/>

            <!-- Notes panel -->
            <Grid Grid.Row="3"
                  BorderBrush="{StaticResource AppDividerBrush}"
                  BorderThickness="0,1,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Button Grid.Row="0"
                        Command="{x:Bind Notes.ToggleCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="16,8"
                        CornerRadius="0"
                        ToolTipService.ToolTip="Ctrl+S to save">
                    <Grid>
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <FontIcon Glyph="{x:Bind Notes.ChevronGlyph, Mode=OneWay}"
                                      FontSize="12"
                                      VerticalAlignment="Center"/>
                            <TextBlock Text="Notes"
                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{x:Bind Notes.SaveStatusText, Mode=OneWay}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{StaticResource AppTextSecondaryBrush}"
                                   FontStyle="{x:Bind Notes.SaveStatusFontStyle, Mode=OneWay}"
                                   Opacity="{x:Bind Notes.SaveStatusOpacity, Mode=OneWay}"
                                   Visibility="{x:Bind Notes.SaveStatusIsError, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                        <TextBlock Text="{x:Bind Notes.SaveStatusText, Mode=OneWay}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="Red"
                                   Visibility="{x:Bind Notes.SaveStatusIsError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </Grid>
                </Button>

                <StackPanel Grid.Row="1"
                            Visibility="{x:Bind Notes.IsExpanded, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <InfoBar IsOpen="{x:Bind Notes.IsExternalChangeBarVisible, Mode=OneWay}"
                             IsClosable="False"
                             Severity="Warning"
                             Title="File changed externally"
                             Margin="16,0,16,8">
                        <InfoBar.Content>
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,4">
                                <HyperlinkButton Content="Reload"
                                                 Command="{x:Bind Notes.ReloadCommand}"
                                                 Padding="0"/>
                                <TextBlock Text="/"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                <HyperlinkButton Content="Keep my edits"
                                                 Command="{x:Bind Notes.KeepEditsCommand}"
                                                 Padding="0"/>
                            </StackPanel>
                        </InfoBar.Content>
                    </InfoBar>
                    <TextBox x:Name="NotesTextBox"
                             Text="{x:Bind Notes.NotesContent, Mode=TwoWay}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             FontFamily="Cascadia Mono"
                             Height="{x:Bind Notes.PanelHeight, Mode=OneWay}"
                             Margin="16,0,16,16"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             PreviewKeyDown="NotesTextBox_PreviewKeyDown"/>
                </StackPanel>
            </Grid>
            </Grid>

            <!-- Kanban / viewer splitter -->
            <local:KanbanSplitter Grid.Column="1"
                                  Width="6"
                                  Background="{StaticResource AppDividerBrush}"
                                  Visibility="{x:Bind SkillViewer.IsOpen, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                  PointerPressed="KanbanSplitter_PointerPressed"
                                  PointerMoved="KanbanSplitter_PointerMoved"
                                  PointerReleased="KanbanSplitter_PointerReleased"
                                  PointerCaptureLost="KanbanSplitter_PointerCaptureLost"/>

            <!-- SKILL.md viewer panel -->
            <Grid Grid.Column="2"
                  Width="{x:Bind SkillViewer.PanelWidth, Mode=OneWay}"
                  MinWidth="280"
                  MaxWidth="2000"
                  Background="{StaticResource AppSurfaceBrush}"
                  BorderBrush="{StaticResource AppDividerBrush}"
                  BorderThickness="1,0,0,0"
                  Visibility="{x:Bind SkillViewer.IsOpen, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                  KeyDown="SkillViewer_KeyDown">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Padding="12,8"
                            Spacing="6"
                            BorderBrush="{StaticResource AppDividerBrush}"
                            BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{x:Bind SkillViewer.SkillName, Mode=OneWay}"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="4"
                                    VerticalAlignment="Center">
                            <Button x:Name="SkillViewerModelButton"
                                    Padding="6,2"
                                    Content="{x:Bind SkillViewer.ModelLabel, Mode=OneWay}"
                                    ToolTipService.ToolTip="Model"
                                    FontSize="12"
                                    MinWidth="90"/>
                            <Button Padding="6,2"
                                    ToolTipService.ToolTip="Launch"
                                    Click="SkillViewerLaunch_Click">
                                <FontIcon Glyph="&#xE768;" FontSize="12"/>
                            </Button>
                            <Button Padding="6,2"
                                    ToolTipService.ToolTip="Refresh from disk"
                                    Command="{x:Bind SkillViewer.RefreshCommand}">
                                <FontIcon Glyph="&#xE72C;" FontSize="12"/>
                            </Button>
                            <Button Padding="6,2"
                                    ToolTipService.ToolTip="Close"
                                    Command="{x:Bind SkillViewer.CloseCommand}">
                                <FontIcon Glyph="&#xE711;" FontSize="12"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal"
                                Spacing="12"
                                Visibility="{x:Bind SkillViewer.HasMetadata, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{x:Bind SkillViewer.ScopeText, Mode=OneWay}"
                                   FontSize="11"
                                   Foreground="{StaticResource AppTextSecondaryBrush}"/>
                        <TextBlock Text="{x:Bind SkillViewer.CommandText, Mode=OneWay}"
                                   FontSize="11"
                                   FontFamily="Cascadia Mono"
                                   Foreground="{StaticResource AppTextSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              Padding="12,8,12,12"
                              VerticalScrollBarVisibility="Auto">
                    <controls:MarkdownTextBlock Text="{x:Bind SkillViewer.MarkdownBody, Mode=OneWay}"
                                                Foreground="{StaticResource AppTextPrimaryBrush}"/>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Page>
