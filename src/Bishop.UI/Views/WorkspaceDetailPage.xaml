<Page
    x:Class="Bishop.UI.Views.WorkspaceDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Persistent header bar -->
        <Grid Grid.Row="0" Padding="16,12"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                <TextBlock x:Name="WorkspaceNameText"
                           Style="{StaticResource SubtitleTextBlockStyle}"/>
                <TextBlock x:Name="WorkspacePathText"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <Grid x:Name="LaunchButtonWrapper"
                  Grid.Column="1"
                  VerticalAlignment="Center"
                  Margin="16,0,0,0">
                <Button x:Name="LaunchButton"
                        Content="Launch Terminal"
                        Click="LaunchButton_Click"/>
            </Grid>
        </Grid>

        <!-- Content area -->
        <StackPanel Grid.Row="1" Padding="16" Spacing="12">
            <InfoBar x:Name="PathWarningBar"
                     IsOpen="False"
                     IsClosable="False"
                     Severity="Warning"
                     Title="Directory not found"
                     Message="The workspace directory is missing. Right-click the workspace and choose Repath to locate it."/>
            <InfoBar x:Name="FallbackWarningBar"
                     IsOpen="False"
                     IsClosable="True"
                     Severity="Informational"
                     Title="Windows Terminal not detected"
                     Message="PowerShell opened instead — claude was not auto-started. If Windows Terminal is installed, enable its app execution alias in Settings → Apps → Advanced app settings → App execution aliases.">
                <InfoBar.ActionButton>
                    <HyperlinkButton Content="Get Windows Terminal"
                                     NavigateUri="https://aka.ms/terminal"/>
                </InfoBar.ActionButton>
            </InfoBar>
        </StackPanel>
    </Grid>
</Page>
