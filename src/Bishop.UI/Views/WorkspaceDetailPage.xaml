<Page
    x:Class="Bishop.UI.Views.WorkspaceDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
            <TextBlock x:Name="WorkspaceNameText"
                       Style="{StaticResource TitleTextBlockStyle}"
                       HorizontalAlignment="Center"/>
            <TextBlock x:Name="WorkspacePathText"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center"/>
            <InfoBar x:Name="PathWarningBar"
                     IsOpen="False"
                     IsClosable="False"
                     Severity="Warning"
                     Title="Directory not found"
                     Message="The workspace directory is missing. Right-click the workspace and choose Repath to locate it."/>
            <Button x:Name="LaunchButton"
                    Content="Launch in Claude Code"
                    HorizontalAlignment="Center"
                    Click="LaunchButton_Click"/>
        </StackPanel>
    </Grid>
</Page>
