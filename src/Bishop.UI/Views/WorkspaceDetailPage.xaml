<Page
    x:Class="Bishop.UI.Views.WorkspaceDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Bishop.UI.ViewModels">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Persistent header bar -->
        <Grid Grid.Row="0" Padding="16,12"
              BorderBrush="{StaticResource AppDividerBrush}"
              BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                <TextBlock x:Name="WorkspaceNameText"
                           Style="{StaticResource SubtitleTextBlockStyle}"/>
                <TextBlock x:Name="WorkspacePathText"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
            </StackPanel>

            <Grid x:Name="LaunchButtonWrapper"
                  Grid.Column="1"
                  VerticalAlignment="Center"
                  Margin="16,0,0,0">
                <Button x:Name="LaunchButton"
                        Content="Launch Terminal"
                        Click="LaunchButton_Click"/>
            </Grid>
        </Grid>

        <!-- Content area -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Notification bars -->
            <StackPanel Grid.Row="0" Padding="16,12,16,0" Spacing="8">
                <InfoBar x:Name="PathWarningBar"
                         IsOpen="False"
                         IsClosable="False"
                         Severity="Warning"
                         Title="Directory not found"
                         Message="The workspace directory is missing. Right-click the workspace and choose Repath to locate it."/>
                <InfoBar x:Name="FallbackWarningBar"
                         IsOpen="False"
                         IsClosable="True"
                         Severity="Informational"
                         Title="Windows Terminal not detected"
                         Message="PowerShell opened instead — claude was not auto-started. If Windows Terminal is installed, enable its app execution alias in Settings → Apps → Advanced app settings → App execution aliases.">
                    <InfoBar.ActionButton>
                        <HyperlinkButton Content="Get Windows Terminal"
                                         NavigateUri="https://aka.ms/terminal"/>
                    </InfoBar.ActionButton>
                </InfoBar>
                <InfoBar x:Name="LaneErrorBar"
                         IsOpen="False"
                         IsClosable="True"
                         Severity="Error"/>
            </StackPanel>

            <!-- Board subheader -->
            <Grid Grid.Row="1" Padding="16,8"
                  BorderBrush="{StaticResource AppDividerBrush}"
                  BorderThickness="0,0,0,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Board"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button x:Name="AddLaneButton"
                            Content="+ New lane"
                            Click="AddLane_Click"/>
                    <Button Command="{x:Bind Board.RefreshCommand}"
                            Content="Refresh"/>
                </StackPanel>
            </Grid>

            <!-- Kanban lanes -->
            <ScrollViewer Grid.Row="2"
                          HorizontalScrollMode="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          Padding="8,12">
                <ListView x:Name="LanesListView"
                          ItemsSource="{x:Bind Board.Lanes}"
                          SelectionMode="None"
                          CanReorderItems="True"
                          AllowDrop="True"
                          DragItemsCompleted="Lanes_DragItemsCompleted">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8"/>
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="VerticalContentAlignment" Value="Top"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:LaneViewModel">
                            <Grid Width="220"
                                  VerticalAlignment="Top"
                                  Background="{StaticResource AppLaneBackgroundBrush}"
                                  CornerRadius="8"
                                  Padding="0,0,0,8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" RightTapped="LaneHeader_RightTapped">
                                    <TextBlock Text="{x:Bind Name, Mode=OneWay}"
                                               Style="{StaticResource BodyStrongTextBlockStyle}"
                                               Padding="12,10,12,8"/>
                                    <FlyoutBase.AttachedFlyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem Text="Rename" Click="RenameLane_Click">
                                                <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8AC;"/></MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            <MenuFlyoutSeparator/>
                                            <MenuFlyoutItem Text="Delete" Click="DeleteLane_Click">
                                                <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74D;"/></MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                        </MenuFlyout>
                                    </FlyoutBase.AttachedFlyout>
                                </Grid>

                                <ListView Grid.Row="1"
                                          ItemsSource="{x:Bind Cards}"
                                          SelectionMode="None"
                                          AllowDrop="True"
                                          MinHeight="40"
                                          DragOver="Cards_DragOver"
                                          DragLeave="Cards_DragLeave"
                                          Drop="Cards_Drop">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="vm:CardViewModel">
                                            <Border Background="{StaticResource AppCardBackgroundBrush}"
                                                    CornerRadius="4"
                                                    Padding="10,8"
                                                    Margin="8,0,8,4"
                                                    CanDrag="True"
                                                    DragStarting="Card_DragStarting">
                                                <Grid ColumnSpacing="4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{x:Bind Title}"
                                                               TextWrapping="Wrap"
                                                               VerticalAlignment="Center"/>
                                                    <Button Grid.Column="1"
                                                            Style="{StaticResource DateTimePickerFlyoutButtonStyle}"
                                                            ToolTipService.ToolTip="View card"
                                                            Click="ViewCard_Click"
                                                            VerticalAlignment="Center">
                                                        <FontIcon Glyph="&#xE7B3;" FontSize="12"/>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <TextBlock Grid.Row="2"
                                           Text="No cards"
                                           Visibility="{x:Bind EmptyPlaceholderVisibility, Mode=OneWay}"
                                           Foreground="{StaticResource AppTextTertiaryBrush}"
                                           FontStyle="Italic"
                                           Padding="12,4"/>

                                <!-- Drag-target highlight overlay -->
                                <Border Grid.RowSpan="3"
                                        IsHitTestVisible="False"
                                        CornerRadius="8"
                                        BorderBrush="{StaticResource AppDragTargetBorderBrush}"
                                        BorderThickness="2"
                                        Background="{StaticResource AppDragTargetBrush}"
                                        Visibility="{x:Bind IsDropTarget, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </ScrollViewer>

            <!-- Notes panel -->
            <Grid Grid.Row="3"
                  BorderBrush="{StaticResource AppDividerBrush}"
                  BorderThickness="0,1,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Button Grid.Row="0"
                        Command="{x:Bind Notes.ToggleCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="16,8"
                        CornerRadius="0">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="{x:Bind Notes.ChevronGlyph, Mode=OneWay}"
                                  FontSize="12"
                                  VerticalAlignment="Center"/>
                        <TextBlock Text="Notes"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <StackPanel Grid.Row="1"
                            Visibility="{x:Bind Notes.IsExpanded, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <InfoBar IsOpen="{x:Bind Notes.IsExternalChangeBarVisible, Mode=OneWay}"
                             IsClosable="False"
                             Severity="Warning"
                             Title="File changed externally"
                             Margin="16,0,16,8">
                        <InfoBar.Content>
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,4">
                                <HyperlinkButton Content="Reload"
                                                 Command="{x:Bind Notes.ReloadCommand}"
                                                 Padding="0"/>
                                <TextBlock Text="/"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                <HyperlinkButton Content="Keep my edits"
                                                 Command="{x:Bind Notes.KeepEditsCommand}"
                                                 Padding="0"/>
                            </StackPanel>
                        </InfoBar.Content>
                    </InfoBar>
                    <TextBox Text="{x:Bind Notes.NotesContent, Mode=TwoWay}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             FontFamily="Cascadia Mono"
                             Height="200"
                             Margin="16,0,16,16"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
