<Page
    x:Class="Bishop.UI.Views.WorkspaceDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Bishop.UI.Views"
    xmlns:vm="using:Bishop.ViewModels"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Compact header bar -->
        <Grid Grid.Row="0" Padding="16,0"
              MinHeight="48"
              BorderBrush="{StaticResource AppDividerBrush}"
              BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="1">
                <TextBlock x:Name="WorkspaceNameText"
                           Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <TextBlock x:Name="WorkspacePathText"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{StaticResource AppTextSecondaryBrush}"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <!-- Search box with custom-coloured fake placeholder -->
            <Grid Grid.Column="1" VerticalAlignment="Center" Margin="8,0" Width="150">
                <TextBox x:Name="CardSearchBox"
                         Text="{x:Bind Board.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         MinHeight="0"
                         PreviewKeyDown="CardSearch_PreviewKeyDown">
                    <TextBox.Resources>
                        <Thickness x:Key="TextControlThemePadding">10,4,10,4</Thickness>
                    </TextBox.Resources>
                </TextBox>
                <TextBlock Text="Search cards…"
                           Foreground="#44FFFFFF"
                           VerticalAlignment="Center"
                           Margin="11,0,0,0"
                           IsHitTestVisible="False"
                           Visibility="{x:Bind Board.IsSearchEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>

            <StackPanel x:Name="LaunchButtonWrapper"
                        Grid.Column="2"
                        Orientation="Horizontal"
                        Spacing="4"
                        VerticalAlignment="Center"
                        Margin="16,0,0,0">
                <Button x:Name="WorkspaceSkillsButton"
                        Padding="8,4"
                        Visibility="Collapsed"
                        Click="WorkspaceSkillsButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xEBD2;" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text="Skills" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="CommitsButton"
                        Padding="8,4"
                        Click="CommitsButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE81C;" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text="Commits" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="TerminalButton"
                        Padding="8,4"
                        Click="TerminalButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8A7;" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text="Terminal" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="ClaudeButton"
                        Padding="8,4"
                        Click="ClaudeButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE768;" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text="Claude" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="WorkspaceSettingsButton"
                        ToolTipService.ToolTip="Workspace settings"
                        Style="{StaticResource SubtleIconButtonStyle}"
                        Click="WorkspaceSettingsButton_Click">
                    <FontIcon Glyph="&#xE713;" FontSize="14" Foreground="{StaticResource AppTextPrimaryBrush}"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Content area -->
        <Grid Grid.Row="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

            <!-- Board + Monitoring tabs -->
            <TabView Grid.Row="0"
                     IsAddTabButtonVisible="False"
                     CanDragTabs="False"
                     CanReorderTabs="False"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Stretch">

                <TabViewItem Header="Board" IsClosable="False">
                    <TabViewItem.Content>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                        <!-- Notification bars — collapsed when no InfoBar is open -->
                        <StackPanel x:Name="NotificationPanel"
                                    Grid.Row="0"
                                    Padding="16,12,16,0"
                                    Spacing="8"
                                    Visibility="Collapsed">
                <InfoBar x:Name="PathWarningBar"
                         IsOpen="False"
                         IsClosable="False"
                         Severity="Warning"
                         Title="Directory not found"
                         Message="The workspace directory is missing. Right-click the workspace and choose Repath to locate it."/>
                <InfoBar x:Name="FallbackWarningBar"
                         IsOpen="False"
                         IsClosable="True"
                         Severity="Informational"
                         Title="Windows Terminal not detected"
                         Message="PowerShell opened instead — claude was not auto-started. If Windows Terminal is installed, enable its app execution alias in Settings → Apps → Advanced app settings → App execution aliases."
                         Closed="InfoBar_Closed">
                    <InfoBar.ActionButton>
                        <HyperlinkButton Content="Get Windows Terminal"
                                         NavigateUri="https://aka.ms/terminal"/>
                    </InfoBar.ActionButton>
                </InfoBar>
                <InfoBar x:Name="CopiedBar"
                         IsOpen="False"
                         IsClosable="False"
                         Severity="Success"
                         Title="Copied to clipboard"/>
            </StackPanel>

            <!-- Kanban lanes -->
            <ScrollViewer Grid.Row="1"
                          HorizontalScrollMode="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          Padding="8,4,8,12">
                <ListView x:Name="LanesListView"
                          ItemsSource="{x:Bind Board.Lanes}"
                          SelectionMode="None">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsStackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,8,0"/>
                            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:LaneViewModel">
                            <Grid Width="220"
                                  VerticalAlignment="Stretch"
                                  Background="{StaticResource AppLaneBackgroundBrush}"
                                  CornerRadius="8"
                                  Padding="0,0,0,8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{x:Bind DisplayName, Mode=OneWay}"
                                               Style="{StaticResource BodyStrongTextBlockStyle}"
                                               Padding="12,10,12,8"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Style="{StaticResource DateTimePickerFlyoutButtonStyle}"
                                                Click="WorkNext_Click"
                                                Visibility="{x:Bind IsPlayVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                                IsEnabled="{x:Bind CanPlayWorkNext, Mode=OneWay}"
                                                ToolTipService.ToolTip="{x:Bind WorkNextTooltip, Mode=OneWay}"
                                                Margin="0,0,4,0">
                                            <FontIcon Glyph="&#xE768;" FontSize="12"/>
                                        </Button>
                                        <Button Style="{StaticResource DateTimePickerFlyoutButtonStyle}"
                                                Click="WorkNextStop_Click"
                                                Visibility="{x:Bind IsStopVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                                IsEnabled="{x:Bind CanStopWorkNext, Mode=OneWay}"
                                                ToolTipService.ToolTip="{x:Bind StopWorkNextTooltip, Mode=OneWay}"
                                                Margin="0,0,4,0">
                                            <FontIcon Glyph="&#xE71A;" FontSize="12"/>
                                        </Button>
                                        <Button Style="{StaticResource DateTimePickerFlyoutButtonStyle}"
                                                Click="ImportFromGitHub_Click"
                                                Visibility="{x:Bind IsImportVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                                ToolTipService.ToolTip="Import from GitHub"
                                                Margin="0,0,4,0">
                                            <FontIcon Glyph="&#xE70D;" FontSize="12"/>
                                        </Button>
                                        <Button Style="{StaticResource DateTimePickerFlyoutButtonStyle}"
                                                Click="PushToGitHub_Click"
                                                Visibility="{x:Bind IsPushToGitHubVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                                ToolTipService.ToolTip="Push to GitHub"
                                                Margin="0,0,4,0">
                                            <FontIcon Glyph="&#xE70E;" FontSize="12"/>
                                        </Button>
                                        <Button Style="{StaticResource DateTimePickerFlyoutButtonStyle}"
                                                Command="{x:Bind BeginAddCardCommand}"
                                                Click="BeginAddCard_Click"
                                                Margin="0,0,8,0"
                                                ToolTipService.ToolTip="Add card">
                                            <FontIcon Glyph="&#xE710;" FontSize="12"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <Grid Grid.Row="1"
                                      AllowDrop="True"
                                      DragOver="Cards_DragOver"
                                      DragLeave="Cards_DragLeave"
                                      Drop="Cards_Drop">
                                    <ScrollViewer VerticalScrollMode="Auto"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollMode="Disabled"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel>
                                            <!-- Add card input -->
                                            <StackPanel Spacing="4"
                                                        Margin="8,4,8,4"
                                                        Visibility="{x:Bind IsAddingCard, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBox PlaceholderText="Card title"
                                                         Text="{x:Bind NewCardTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         PreviewKeyDown="AddCardTextBox_PreviewKeyDown"/>
                                                <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right">
                                                    <Button Content="&#x2713;"
                                                            Command="{x:Bind ConfirmAddCardCommand}"
                                                            ToolTipService.ToolTip="Add card (Enter)"/>
                                                    <Button Content="&#x2715;"
                                                            Command="{x:Bind CancelAddCardCommand}"
                                                            ToolTipService.ToolTip="Cancel (Escape)"/>
                                                </StackPanel>
                                                <TextBlock Text="{x:Bind AddCardErrorMessage, Mode=OneWay}"
                                                           Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                                           TextWrapping="Wrap"
                                                           FontSize="12"
                                                           Visibility="{x:Bind HasAddCardError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            </StackPanel>

                                            <!-- Card list (virtualised) -->
                                            <ItemsRepeater ItemsSource="{x:Bind FilteredCards}">
                                                <ItemsRepeater.Layout>
                                                    <StackLayout Orientation="Vertical"/>
                                                </ItemsRepeater.Layout>
                                                <ItemsRepeater.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:CardViewModel">
                                                        <Grid Margin="8,0,8,4"
                                                              Opacity="{x:Bind CardOpacity}">
                                                            <Border Background="{StaticResource AppCardBackgroundBrush}"
                                                                    CornerRadius="4">
                                                            <StackPanel>
                                                                <!-- Card header: drag handle -->
                                                                <local:SizeAllCursorGrid Padding="{x:Bind IsDoneLane, Converter={StaticResource BoolToThicknessConverter}, ConverterParameter='10,2,4,2|10,4,4,4'}"
                                                                                         Background="Transparent"
                                                                                         BorderBrush="{StaticResource AppDividerBrush}"
                                                                                         BorderThickness="0,0,0,1"
                                                                                         CanDrag="True"
                                                                                         DragStarting="Card_DragStarting"
                                                                                         DropCompleted="Card_DropCompleted">
                                                                    <local:SizeAllCursorGrid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </local:SizeAllCursorGrid.ColumnDefinitions>
                                                                    <StackPanel Grid.Column="0"
                                                                                Orientation="Horizontal"
                                                                                Spacing="6"
                                                                                VerticalAlignment="Center">
                                                                        <TextBlock Text="{x:Bind NumberDisplay}"
                                                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                                                   Foreground="{StaticResource AppTextTertiaryBrush}"
                                                                                   FontFamily="Cascadia Mono"
                                                                                   VerticalAlignment="Center"/>
                                                                        <local:HandCursorButton Background="Transparent"
                                                                                               BorderThickness="0"
                                                                                               Padding="0"
                                                                                               MinWidth="0"
                                                                                               MinHeight="0"
                                                                                               Click="CardTagChip_Click"
                                                                                               ToolTipService.ToolTip="Change tag"
                                                                                               Visibility="{x:Bind IsTagVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                                               VerticalAlignment="Center">
                                                                            <Border Background="{x:Bind TagColour, Converter={StaticResource HexColorToBrushConverter}}"
                                                                                    CornerRadius="3"
                                                                                    Padding="5,1">
                                                                                <TextBlock Text="{x:Bind TagName}"
                                                                                           Style="{StaticResource CaptionTextBlockStyle}"
                                                                                           Foreground="{x:Bind TagColour, Converter={StaticResource HexColorToContrastForegroundConverter}}"
                                                                                           VerticalAlignment="Center"/>
                                                                            </Border>
                                                                        </local:HandCursorButton>
                                                                        <local:HandCursorButton Click="CardAddTagButton_Click"
                                                                                               Visibility="{x:Bind IsAddTagButtonVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                                               Padding="5,1"
                                                                                               BorderThickness="0"
                                                                                               CornerRadius="3"
                                                                                               Background="{StaticResource AppDividerBrush}">
                                                                            <TextBlock Text="+ tag"
                                                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                                                       VerticalAlignment="Center"/>
                                                                        </local:HandCursorButton>
                                                                    </StackPanel>
                                                                    <StackPanel Grid.Column="1"
                                                                                Orientation="Horizontal">
                                                                        <FontIcon Glyph="&#xE99A;"
                                                                                  Foreground="#ff5555"
                                                                                  FontSize="12"
                                                                                  VerticalAlignment="Center"
                                                                                  Margin="0,0,4,0"
                                                                                  ToolTipService.ToolTip="{x:Bind AutoRunFailedTooltip}"
                                                                                  Visibility="{x:Bind IsAutoRunFailedIndicatorVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                                        <local:HandCursorButton Style="{StaticResource DateTimePickerFlyoutButtonStyle}"
                                                                                               ToolTipService.ToolTip="Skills"
                                                                                               Click="CardSkillsButton_Click"
                                                                                               Visibility="{x:Bind IsSkillsButtonVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                                               VerticalAlignment="Center">
                                                                            <FontIcon Glyph="&#xEBD2;" FontSize="12"/>
                                                                        </local:HandCursorButton>
                                                                        <local:HandCursorButton Style="{StaticResource DateTimePickerFlyoutButtonStyle}"
                                                                                               ToolTipService.ToolTip="{x:Bind CloseReopenTooltip}"
                                                                                               Click="CardCloseButton_Click"
                                                                                               VerticalAlignment="Center">
                                                                            <FontIcon Glyph="{x:Bind CloseReopenGlyph}" FontSize="12"/>
                                                                        </local:HandCursorButton>
                                                                    </StackPanel>
                                                                </local:SizeAllCursorGrid>
                                                                <!-- Card title: tap to open detail -->
                                                                <local:HandCursorGrid>
                                                                    <TextBlock Text="{x:Bind Title}"
                                                                               TextWrapping="Wrap"
                                                                               Padding="{x:Bind IsDoneLane, Converter={StaticResource BoolToThicknessConverter}, ConverterParameter='10,3,10,4|10,6,10,8'}"
                                                                               FontSize="{x:Bind CardTitleFontSize}"
                                                                               Tapped="CardTitle_Tapped"/>
                                                                </local:HandCursorGrid>
                                                            </StackPanel>
                                                            </Border>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsRepeater.ItemTemplate>
                                            </ItemsRepeater>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>


<!-- Drag-target highlight overlay -->
                                <Border Grid.RowSpan="2"
                                        IsHitTestVisible="False"
                                        CornerRadius="8"
                                        BorderBrush="{StaticResource AppDragTargetBorderBrush}"
                                        BorderThickness="2"
                                        Background="{StaticResource AppDragTargetBrush}"
                                        Visibility="{x:Bind IsDropTarget, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </ScrollViewer>

                        </Grid>
                    </TabViewItem.Content>
                </TabViewItem>

                <TabViewItem IsClosable="False">
                    <TabViewItem.Header>
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="Monitoring" VerticalAlignment="Center"/>
                            <Grid MinWidth="16" MinHeight="16"
                                  Visibility="{x:Bind Monitoring.BadgeIsVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                  ToolTipService.ToolTip="{x:Bind Monitoring.BadgeTooltip, Mode=OneWay}">
                                <Rectangle RadiusX="8" RadiusY="8"
                                           Fill="{x:Bind Monitoring.BadgeColor, Mode=OneWay, Converter={StaticResource HexColorToBrushConverter}}"/>
                                <TextBlock Text="{x:Bind Monitoring.BadgeCount, Mode=OneWay}"
                                           Foreground="{x:Bind Monitoring.BadgeColor, Mode=OneWay, Converter={StaticResource HexColorToContrastForegroundConverter}}"
                                           FontSize="11"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="6,1"/>
                            </Grid>
                        </StackPanel>
                    </TabViewItem.Header>
                    <TabViewItem.Content>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Table header -->
                            <Grid Grid.Row="0"
                                  Padding="16,12,16,8"
                                  BorderBrush="{StaticResource AppDividerBrush}"
                                  BorderThickness="0,0,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Skill"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="Last run"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                <TextBlock Grid.Column="2" Text="Commits since"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                <TextBlock Grid.Column="3" Text="Status"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                            </Grid>

                            <!-- Skill run rows -->
                            <ListView Grid.Row="1"
                                      ItemsSource="{x:Bind Monitoring.Rows}"
                                      SelectionMode="None"
                                      Padding="0,4,0,12">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:SkillRunRowViewModel">
                                        <Grid Padding="16,8"
                                              BorderBrush="{StaticResource AppDividerBrush}"
                                              BorderThickness="0,0,0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="160"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{x:Bind SkillName}"
                                                       FontFamily="Cascadia Mono"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{x:Bind LastRunText}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{x:Bind CommitsSinceText}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"/>
                                            <Ellipse Grid.Column="3"
                                                     Width="10"
                                                     Height="10"
                                                     Fill="{x:Bind StatusDotColor, Converter={StaticResource HexColorToBrushConverter}}"
                                                     VerticalAlignment="Center"
                                                     ToolTipService.ToolTip="{x:Bind StatusTooltip}"/>
                                            <StackPanel Grid.Column="4"
                                                        Orientation="Horizontal"
                                                        Spacing="6"
                                                        VerticalAlignment="Center">
                                                <Button Content="{x:Bind SelectedModelLabel, Mode=OneWay}"
                                                        Width="100"
                                                        Padding="8,4"
                                                        FontSize="12"
                                                        VerticalAlignment="Center">
                                                    <Button.Flyout>
                                                        <MenuFlyout>
                                                            <MenuFlyoutItem Text="Opus 4.7"
                                                                            Command="{x:Bind SelectModelCommand}"
                                                                            CommandParameter="claude-opus-4-7"/>
                                                            <MenuFlyoutItem Text="Sonnet 4.6"
                                                                            Command="{x:Bind SelectModelCommand}"
                                                                            CommandParameter="claude-sonnet-4-6"/>
                                                            <MenuFlyoutItem Text="Haiku 4.5"
                                                                            Command="{x:Bind SelectModelCommand}"
                                                                            CommandParameter="claude-haiku-4-5-20251001"/>
                                                        </MenuFlyout>
                                                    </Button.Flyout>
                                                </Button>
                                                <Button Content="Run now"
                                                        Padding="8,4"
                                                        FontSize="12"
                                                        Click="RunNowSkillButton_Click"
                                                        VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </TabViewItem.Content>
                </TabViewItem>
            </TabView>

            <!-- Notes splitter -->
            <local:NotesSplitter Grid.Row="1"
                                 Height="6"
                                 Background="{StaticResource AppDividerBrush}"
                                 Visibility="{x:Bind Notes.IsExpanded, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                 PointerPressed="NotesSplitter_PointerPressed"
                                 PointerMoved="NotesSplitter_PointerMoved"
                                 PointerReleased="NotesSplitter_PointerReleased"
                                 PointerCaptureLost="NotesSplitter_PointerCaptureLost"/>

            <!-- Notes panel -->
            <Grid Grid.Row="2"
                  BorderBrush="{StaticResource AppDividerBrush}"
                  BorderThickness="0,1,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Button Grid.Row="0"
                        Command="{x:Bind Notes.ToggleCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="16,8"
                        CornerRadius="0"
                        ToolTipService.ToolTip="Ctrl+S to save">
                    <Grid>
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <FontIcon Glyph="{x:Bind Notes.ChevronGlyph, Mode=OneWay}"
                                      FontSize="12"
                                      VerticalAlignment="Center"/>
                            <TextBlock Text="Notes"
                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{x:Bind Notes.SaveStatusText, Mode=OneWay}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{StaticResource AppTextSecondaryBrush}"
                                   FontStyle="{x:Bind Notes.SaveStatusIsEditing, Mode=OneWay, Converter={StaticResource BoolToFontStyleConverter}}"
                                   Opacity="{x:Bind Notes.SaveStatusOpacity, Mode=OneWay}"
                                   Visibility="{x:Bind Notes.SaveStatusIsError, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                        <TextBlock Text="{x:Bind Notes.SaveStatusText, Mode=OneWay}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="Red"
                                   Visibility="{x:Bind Notes.SaveStatusIsError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </Grid>
                </Button>

                <StackPanel Grid.Row="1"
                            Visibility="{x:Bind Notes.IsExpanded, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <InfoBar IsOpen="{x:Bind Notes.IsExternalChangeBarVisible, Mode=OneWay}"
                             IsClosable="False"
                             Severity="Warning"
                             Title="File changed externally"
                             Margin="16,0,16,8">
                        <InfoBar.Content>
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,4">
                                <HyperlinkButton Content="Reload"
                                                 Command="{x:Bind Notes.ReloadCommand}"
                                                 Padding="0"/>
                                <TextBlock Text="/"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                <HyperlinkButton Content="Keep my edits"
                                                 Command="{x:Bind Notes.KeepEditsCommand}"
                                                 Padding="0"/>
                            </StackPanel>
                        </InfoBar.Content>
                    </InfoBar>
                    <TextBox x:Name="NotesTextBox"
                             Text="{x:Bind Notes.NotesContent, Mode=TwoWay}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             FontFamily="Cascadia Mono"
                             Height="{x:Bind Notes.PanelHeight, Mode=OneWay}"
                             Margin="16,0,16,16"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             PreviewKeyDown="NotesTextBox_PreviewKeyDown"/>
                </StackPanel>
            </Grid>
            </Grid>

        </Grid>
    </Grid>
</Page>
