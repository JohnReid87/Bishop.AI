<ContentDialog
    x:Class="Bishop.UI.Views.Cards.CardDetailDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
>
    <ContentDialog.Resources>
        <StaticResource x:Key="ContentDialogBackground" ResourceKey="AppSurfaceElevatedBrush"/>
        <x:Double x:Key="ContentDialogMinWidth">520</x:Double>
        <x:Double x:Key="ContentDialogMaxWidth">780</x:Double>
        <x:Double x:Key="ContentDialogMaxHeight">900</x:Double>
    </ContentDialog.Resources>

    <StackPanel Spacing="0" MinWidth="520" MaxWidth="780" Translation="0,0,32">
        <StackPanel.Shadow>
            <ThemeShadow/>
        </StackPanel.Shadow>

        <!-- Header: #N · lane chip · tags · + | skills | X -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="6"
                        VerticalAlignment="Center">
                <Button Click="BackButton_Click"
                        Style="{StaticResource SubtleIconButtonStyle}"
                        ToolTipService.ToolTip="Back"
                        Visibility="{x:Bind ViewModel.CanGoBack, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE72B;" FontSize="12" Foreground="{StaticResource AppTextPrimaryBrush}"/>
                </Button>
                <TextBlock Text="{x:Bind ViewModel.NumberDisplay, Mode=OneWay}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{StaticResource AppTextTertiaryBrush}"
                           FontFamily="Cascadia Mono"
                           VerticalAlignment="Center"/>
                <Border Background="{StaticResource AppCardBackgroundBrush}"
                        CornerRadius="3"
                        Padding="5,1">
                    <TextBlock Text="{x:Bind ViewModel.LaneName, Mode=OneWay}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{StaticResource AppTextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </Border>
                <!-- Tag chip (visible when card has a tag) -->
                <Button Background="Transparent"
                        BorderThickness="0"
                        Padding="0"
                        MinWidth="0"
                        MinHeight="0"
                        Click="TagChip_Click"
                        ToolTipService.ToolTip="Change tag"
                        Visibility="{x:Bind ViewModel.IsTagVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        VerticalAlignment="Center">
                    <Border Background="{x:Bind ViewModel.TagColour, Converter={StaticResource HexColorToBrushConverter}, Mode=OneWay}"
                            CornerRadius="3"
                            Padding="4,1">
                        <TextBlock Text="{x:Bind ViewModel.TagName, Mode=OneWay}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{x:Bind ViewModel.TagColour, Converter={StaticResource HexColorToContrastForegroundConverter}, Mode=OneWay}"
                                   VerticalAlignment="Center"/>
                    </Border>
                </Button>
                <!-- Add tag button (visible when card has no tag) -->
                <Button x:Name="AddTagButton"
                        Click="AddTag_Click"
                        Padding="5,1"
                        BorderThickness="0"
                        CornerRadius="3"
                        VerticalAlignment="Center"
                        Visibility="{x:Bind ViewModel.IsAddTagButtonVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        Background="{StaticResource AppDividerBrush}">
                    <TextBlock Text="+"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{StaticResource AppTextSecondaryBrush}"/>
                </Button>
            </StackPanel>
            <Button Grid.Column="1"
                    Style="{StaticResource SubtleIconButtonStyle}"
                    ToolTipService.ToolTip="Skills"
                    Click="SkillButton_Click"
                    Visibility="{x:Bind ViewModel.IsSkillsButtonVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                    VerticalAlignment="Center">
                <FontIcon Glyph="&#xEBD2;" FontSize="12" Foreground="{StaticResource AppTextPrimaryBrush}"/>
            </Button>
            <Button Grid.Column="2"
                    Style="{StaticResource SubtleIconButtonStyle}"
                    ToolTipService.ToolTip="Close"
                    Click="CloseDialog_Click"
                    VerticalAlignment="Center">
                <FontIcon Glyph="&#xE8BB;" FontSize="12" Foreground="{StaticResource AppTextPrimaryBrush}"/>
            </Button>
        </Grid>

        <!-- Claude totals (cost / tokens / runs) — hidden when no Claude activity yet -->
        <TextBlock Text="{x:Bind ViewModel.ClaudeTotalsText, Mode=OneWay}"
                   Style="{StaticResource CaptionTextBlockStyle}"
                   Foreground="{StaticResource AppTextSecondaryBrush}"
                   FontFamily="Cascadia Mono"
                   Margin="0,0,0,4"
                   Visibility="{x:Bind ViewModel.HasClaudeTotals, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- Last failed run transcript link -->
        <HyperlinkButton Content="View last failed run"
                         Click="ViewLastFailedRun_Click"
                         Visibility="{x:Bind ViewModel.HasFailedRunTranscript, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                         Padding="0"
                         FontSize="12"
                         Margin="0,0,0,6"/>

        <!-- Divider: header / body -->
        <Border Height="1" Background="{StaticResource AppDividerBrush}" Margin="0,0,0,12"/>

        <!-- Title - view mode -->
        <TextBlock Text="{x:Bind ViewModel.Title, Mode=OneWay}"
                   Style="{StaticResource SubtitleTextBlockStyle}"
                   TextWrapping="Wrap"
                   Visibility="{x:Bind ViewModel.IsTitleEditing, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                   Tapped="TitleView_Tapped"/>

        <!-- Title - edit mode -->
        <TextBox x:Name="TitleTextBox"
                 TextWrapping="Wrap"
                 Visibility="{x:Bind ViewModel.IsTitleEditing, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                 LostFocus="TitleTextBox_LostFocus"
                 KeyDown="TitleTextBox_KeyDown"/>

        <!-- Description - view mode (scrollable) -->
        <Grid Margin="0,8,0,0"
              Visibility="{x:Bind ViewModel.IsDescriptionEditing, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <ScrollViewer MaxHeight="480"
                          Background="Transparent"
                          VerticalScrollBarVisibility="Auto">
                <Grid Padding="0,0,32,0">
                    <controls:MarkdownTextBlock
                        x:Name="DescriptionMarkdown"
                        Text="{x:Bind ViewModel.LinkableDescription, Mode=OneWay}"
                        Foreground="{StaticResource AppTextPrimaryBrush}"
                        Visibility="{x:Bind ViewModel.HasDescription, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        UseEmphasisExtras="True"/>
                    <TextBlock
                        Text="No description."
                        FontStyle="Italic"
                        Foreground="{StaticResource AppTextTertiaryBrush}"
                        Visibility="{x:Bind ViewModel.HasDescription, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                        IsHitTestVisible="False"/>
                </Grid>
            </ScrollViewer>
            <Button HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Style="{StaticResource SubtleIconButtonStyle}"
                    ToolTipService.ToolTip="Edit description"
                    Click="DescriptionEdit_Click">
                <Path Data="{StaticResource IconEditData}"
                      Stroke="{StaticResource AppTextPrimaryBrush}"
                      StrokeThickness="1.5"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      StrokeLineJoin="Round"
                      Width="14" Height="14"
                      Stretch="Uniform"/>
            </Button>
        </Grid>

        <!-- Description - edit mode (TextBox scrolls internally when MaxHeight is set) -->
        <TextBox x:Name="DescriptionTextBox"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 MinHeight="80"
                 MaxHeight="480"
                 Margin="0,8,0,0"
                 PlaceholderText="Ctrl+Enter to save, Esc to cancel"
                 Visibility="{x:Bind ViewModel.IsDescriptionEditing, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                 LostFocus="DescriptionTextBox_LostFocus"
                 KeyDown="DescriptionTextBox_KeyDown"/>

        <!-- Divider: body / footer -->
        <Border Height="1" Background="{StaticResource AppDividerBrush}" Margin="0,12,0,10"/>

        <!-- Footer: compact action row -->
        <StackPanel Spacing="4">
            <!-- Inline save error -->
            <TextBlock
                Text="{x:Bind ViewModel.EditError, Mode=OneWay}"
                Foreground="{StaticResource BrushError}"
                TextWrapping="Wrap"
                Visibility="{x:Bind ViewModel.HasEditError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <Grid>
                <!-- Left: Close/Reopen + delete confirmation -->
                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Left">
                    <Button Content="{x:Bind ViewModel.CloseReopenText, Mode=OneWay}"
                            Command="{x:Bind ViewModel.ToggleClosedCommand}"
                            Padding="8,4" FontSize="12"/>

                    <StackPanel Orientation="Horizontal" Spacing="4"
                                Visibility="{x:Bind ViewModel.IsCommitVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="commit"
                                   Foreground="{StaticResource AppTextTertiaryBrush}"
                                   VerticalAlignment="Center" FontSize="12"/>
                        <TextBlock Text="{x:Bind ViewModel.CommitShortHash, Mode=OneWay}"
                                   FontFamily="Cascadia Mono"
                                   VerticalAlignment="Center" FontSize="12"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="6"
                                Visibility="{x:Bind ViewModel.ShowDeleteConfirm, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="Delete this card?"
                                   Foreground="{StaticResource BrushError}"
                                   VerticalAlignment="Center"
                                   FontSize="12"/>
                        <Button Content="Yes, delete"
                                Command="{x:Bind ViewModel.ConfirmDeleteCommand}"
                                Padding="8,4" FontSize="12"/>
                        <Button Content="Cancel"
                                Command="{x:Bind ViewModel.CancelDeleteCommand}"
                                Padding="8,4" FontSize="12"/>
                    </StackPanel>
                </StackPanel>

                <!-- Right: Delete trigger (danger zone) -->
                <Button Content="Delete…"
                        Command="{x:Bind ViewModel.RequestDeleteCommand}"
                        HorizontalAlignment="Right"
                        Foreground="{StaticResource BrushError}"
                        Padding="8,4" FontSize="12"/>
            </Grid>
        </StackPanel>

    </StackPanel>
</ContentDialog>
