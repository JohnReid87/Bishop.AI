<ContentDialog
    x:Class="Bishop.UI.Views.GitHub.ImportFromGitHubDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Import from GitHub"
    PrimaryButtonText="Import"
    CloseButtonText="Cancel"
    DefaultButton="Close">
    <ContentDialog.Resources>
        <SolidColorBrush x:Key="ContentDialogBackground" Color="#141414"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"
            xmlns:converters="using:Bishop.UI.Converters"/>
    </ContentDialog.Resources>
    <StackPanel Spacing="12" MinWidth="360">
        <StackPanel Spacing="4">
            <TextBlock Text="Label" Style="{StaticResource CaptionTextBlockStyle}"/>
            <ComboBox ItemsSource="{x:Bind ViewModel.Labels, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedLabel, Mode=TwoWay}"
                      IsEnabled="{x:Bind ViewModel.IsIdle, Mode=OneWay}"
                      HorizontalAlignment="Stretch"/>
        </StackPanel>
        <StackPanel Spacing="4">
            <TextBlock Text="Limit" Style="{StaticResource CaptionTextBlockStyle}"/>
            <TextBox InputScope="Number"
                     Text="{x:Bind ViewModel.LimitText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     IsEnabled="{x:Bind ViewModel.IsIdle, Mode=OneWay}"/>
        </StackPanel>
        <Button Content="Preview"
                Click="Preview_Click"
                IsEnabled="{x:Bind ViewModel.IsIdle, Mode=OneWay}"
                HorizontalAlignment="Right"/>
        <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                      Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
        <StackPanel Spacing="4"
                    Visibility="{x:Bind ViewModel.HasResults, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="{x:Bind ViewModel.ResultSummary, Mode=OneWay}"
                       Style="{StaticResource CaptionTextBlockStyle}"/>
            <ListView ItemsSource="{x:Bind ViewModel.PreviewItems, Mode=OneWay}"
                      MaxHeight="200"
                      SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <TextBlock Text="{x:Bind}" TextWrapping="Wrap" Padding="0,2"/>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </StackPanel>
</ContentDialog>
