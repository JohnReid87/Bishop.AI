<UserControl
    x:Class="Bishop.UI.Views.ManageWorkspacesControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Bishop.ViewModels"
    xmlns:converters="using:Bishop.UI.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
    </UserControl.Resources>
    <ListView ItemsSource="{x:Bind ViewModel.Workspaces, Mode=OneWay}"
              SelectionMode="None"
              MaxHeight="400"
              ScrollViewer.HorizontalScrollMode="Disabled"
              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
        <ListView.ItemContainerStyle>
            <Style TargetType="ListViewItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Padding" Value="0"/>
            </Style>
        </ListView.ItemContainerStyle>
        <ListView.ItemTemplate>
            <DataTemplate x:DataType="vm:WorkspaceManagerItemViewModel">
                <Grid ColumnSpacing="12" Padding="8,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="{x:Bind Name}"
                                   FontSize="13"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="{x:Bind Path}"
                                   FontSize="11"
                                   Opacity="0.5"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="280"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Text="{x:Bind StatusText}"
                               FontSize="11"
                               Opacity="0.6"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="120"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="4"
                                VerticalAlignment="Center">
                        <Button Content="Remove"
                                Visibility="{x:Bind IsRemoved, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                Click="RemoveButton_Click"
                                Tag="{x:Bind}"
                                Padding="10,4"/>
                        <Button Content="Purge"
                                Visibility="{x:Bind IsRemoved, Converter={StaticResource BoolToVisibilityConverter}}"
                                Click="PurgeButton_Click"
                                Tag="{x:Bind}"
                                Padding="10,4"/>
                    </StackPanel>
                </Grid>
            </DataTemplate>
        </ListView.ItemTemplate>
    </ListView>
</UserControl>
