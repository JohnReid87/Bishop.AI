<Page
    x:Class="Bishop.UI.Views.Game.GamePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#141414">
    <Grid x:Name="RootGrid"
          IsTabStop="True"
          PreviewKeyDown="RootGrid_PreviewKeyDown"
          PreviewKeyUp="RootGrid_PreviewKeyUp"
          PointerPressed="RootGrid_PointerPressed">

        <!-- Playfield — engine coordinate space is 800×600 -->
        <Viewbox HorizontalAlignment="Center" VerticalAlignment="Center">
            <Canvas x:Name="Playfield" Width="800" Height="600" Background="#0a0a0a"/>
        </Viewbox>

        <!-- HUD: score and lives -->
        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top"
                    Orientation="Horizontal" Spacing="16" Margin="16,12">
            <TextBlock x:Name="ScoreText"
                       FontSize="13"
                       FontFamily="Cascadia Mono, Consolas, Courier New"
                       Foreground="#e8e8e8"/>
            <TextBlock x:Name="LivesText"
                       FontSize="13"
                       FontFamily="Cascadia Mono, Consolas, Courier New"
                       Foreground="#e8e8e8"/>
        </StackPanel>

        <!-- Pause indicator -->
        <TextBlock x:Name="PauseText"
                   Text="PAUSED — P or Esc to resume"
                   FontSize="14"
                   FontFamily="Cascadia Mono, Consolas, Courier New"
                   Foreground="#888888"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="Collapsed"/>

        <!-- WaitingToLaunch hint -->
        <TextBlock x:Name="LaunchHintText"
                   Text="Press Space to launch"
                   FontSize="13"
                   FontFamily="Cascadia Mono, Consolas, Courier New"
                   Foreground="#888888"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,48"/>

        <!-- Game-over / Level-complete overlay -->
        <Grid x:Name="OverlayGrid"
              Visibility="Collapsed"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
            <Border Background="#CC141414" CornerRadius="6" Padding="32,24">
                <StackPanel Spacing="12" HorizontalAlignment="Center">
                    <TextBlock x:Name="OverlayTitle"
                               FontSize="22"
                               FontFamily="Cascadia Mono, Consolas, Courier New"
                               Foreground="#e8e8e8"
                               TextAlignment="Center"/>
                    <TextBlock x:Name="OverlayScore"
                               FontSize="14"
                               FontFamily="Cascadia Mono, Consolas, Courier New"
                               Foreground="#888888"
                               TextAlignment="Center"/>
                    <Button x:Name="PlayAgainButton"
                            Click="PlayAgain_Click"
                            HorizontalAlignment="Center"
                            Margin="0,8,0,0">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackground" Color="#FF00FF41"/>
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FF00B830"/>
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#FF008C26"/>
                            <SolidColorBrush x:Key="ButtonForeground" Color="#FF000000"/>
                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#FF000000"/>
                            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#FF000000"/>
                        </Button.Resources>
                        <TextBlock Text="Play Again" FontSize="13" Foreground="#FF000000"/>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
