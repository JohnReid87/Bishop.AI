<Page
    x:Class="Bishop.UI.Views.Findings.FindingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Bishop.ViewModels.Findings">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header bar -->
        <Grid Grid.Row="0"
              Padding="16,12,16,8"
              BorderBrush="{ThemeResource AppDividerBrush}"
              BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Click="BackButton_Click"
                    Padding="6,2"
                    Margin="0,0,12,0"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE72B;" FontSize="12"/>
                    <TextBlock Text="Back" FontSize="12"/>
                </StackPanel>
            </Button>

            <TextBlock Grid.Column="1"
                       Text="{x:Bind ViewModel.Header, Mode=OneWay}"
                       Style="{ThemeResource SubtitleTextBlockStyle}"
                       VerticalAlignment="Center"/>

            <TextBox Grid.Column="2"
                     PlaceholderText="filter…"
                     Width="220"
                     FontSize="12"
                     Text="{x:Bind ViewModel.FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>

        <!-- Column headers -->
        <Grid Grid.Row="1"
              Padding="16,8,16,8"
              BorderBrush="{ThemeResource AppDividerBrush}"
              BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Click="SortBySeverity_Click"
                    Background="Transparent" BorderThickness="0" Padding="0">
                <TextBlock Text="Severity"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource AppTextSecondaryBrush}"/>
            </Button>
            <Button Grid.Column="1" Click="SortByTitle_Click"
                    Background="Transparent" BorderThickness="0" Padding="0"
                    HorizontalAlignment="Left">
                <TextBlock Text="Title"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource AppTextSecondaryBrush}"/>
            </Button>
            <Button Grid.Column="2" Click="SortByLocation_Click"
                    Background="Transparent" BorderThickness="0" Padding="0"
                    HorizontalAlignment="Left">
                <TextBlock Text="Location"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource AppTextSecondaryBrush}"/>
            </Button>
            <TextBlock Grid.Column="3" Text="Status"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource AppTextSecondaryBrush}"/>
            <TextBlock Grid.Column="4" Text="Action"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource AppTextSecondaryBrush}"/>
        </Grid>

        <!-- Empty-state -->
        <TextBlock Grid.Row="2"
                   Text="No findings."
                   Margin="16,24,16,0"
                   Foreground="{ThemeResource AppTextSecondaryBrush}"
                   Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- Findings rows + resolved section -->
        <ScrollViewer Grid.Row="3">
            <StackPanel>
                <ListView x:Name="FindingsList"
                          ItemsSource="{x:Bind ViewModel.VisibleFindings, Mode=OneWay}"
                          SelectionMode="None">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:FindingItemViewModel">
                            <Grid Padding="16,8"
                                  BorderBrush="{ThemeResource AppDividerBrush}"
                                  BorderThickness="0,0,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="220"/>
                                </Grid.ColumnDefinitions>

                                <!-- Severity chip -->
                                <Border Grid.Column="0"
                                        Background="{x:Bind SeverityColor, Converter={StaticResource HexColorToBrushConverter}}"
                                        CornerRadius="10"
                                        Padding="6,1"
                                        Margin="0,4,0,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Visibility="{x:Bind HasSeverity, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="{x:Bind Severity}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{x:Bind SeverityColor, Converter={StaticResource HexColorToContrastForegroundConverter}}"/>
                                </Border>

                                <!-- Title + expandable body -->
                                <Expander Grid.Column="1"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          HorizontalContentAlignment="Stretch"
                                          HorizontalAlignment="Stretch"
                                          Padding="0">
                                    <Expander.Header>
                                        <TextBlock Text="{x:Bind Title}"
                                                   FontSize="13"
                                                   TextWrapping="Wrap"/>
                                    </Expander.Header>
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="{x:Bind Body}"
                                                   FontFamily="Cascadia Mono, Consolas"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   Foreground="{ThemeResource AppTextSecondaryBrush}"/>
                                        <Border Background="{ThemeResource AppDividerBrush}"
                                                CornerRadius="4"
                                                Padding="8,4"
                                                Visibility="{x:Bind HasRebuttal, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <StackPanel>
                                                <TextBlock Text="Previously dismissed:"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{ThemeResource AppTextSecondaryBrush}"/>
                                                <TextBlock Text="{x:Bind RebuttalText, Mode=OneWay}"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Expander>

                                <!-- Location -->
                                <TextBlock Grid.Column="2"
                                           Text="{x:Bind Location}"
                                           FontFamily="Cascadia Mono, Consolas"
                                           FontSize="12"
                                           Foreground="{ThemeResource AppTextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Top"
                                           Margin="0,4,0,0"/>

                                <!-- Status -->
                                <Grid Grid.Column="3" VerticalAlignment="Top" Margin="0,2,0,0">
                                    <HyperlinkButton Content="{x:Bind StatusLabel, Mode=OneWay}"
                                                     FontSize="12"
                                                     Padding="0"
                                                     Click="OpenLinkedCard_Click"
                                                     Visibility="{x:Bind HasLinkedCard, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    <TextBlock Text="{x:Bind StatusLabel, Mode=OneWay}"
                                               FontSize="12"
                                               Margin="0,2,0,0"
                                               Visibility="{x:Bind HasLinkedCard, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                                </Grid>

                                <!-- Actions -->
                                <StackPanel Grid.Column="4"
                                            Orientation="Horizontal"
                                            Spacing="6"
                                            VerticalAlignment="Top"
                                            Margin="0,2,0,0">
                                    <Button Content="Convert to card"
                                            FontSize="12"
                                            Padding="8,4"
                                            Click="ConvertToCard_Click"
                                            Visibility="{x:Bind IsConvertToCardVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                            IsEnabled="{x:Bind IsConvertToCardVisible, Mode=OneWay}"/>
                                    <Button Content="Dismiss"
                                            FontSize="12"
                                            Padding="8,4"
                                            IsEnabled="{x:Bind IsDismissEnabled, Mode=OneWay}">
                                        <Button.Flyout>
                                            <Flyout x:Name="DismissFlyout">
                                                <StackPanel Width="280" Spacing="8">
                                                    <TextBlock Text="Dismiss with reason"
                                                               FontWeight="SemiBold"/>
                                                    <TextBox PlaceholderText="Why is this not a real finding?"
                                                             AcceptsReturn="True"
                                                             TextWrapping="Wrap"
                                                             MinHeight="60"
                                                             Text="{x:Bind RebuttalDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                    <Button Content="Dismiss"
                                                            HorizontalAlignment="Right"
                                                            Click="Dismiss_Click"
                                                            Tag="{Binding ElementName=DismissFlyout}"/>
                                                </StackPanel>
                                            </Flyout>
                                        </Button.Flyout>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Resolved since last run -->
                <Expander Margin="16,12,16,16"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch"
                          IsExpanded="False"
                          Visibility="{x:Bind ViewModel.HasResolved, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Expander.Header>
                        <TextBlock Text="Resolved since last run"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource AppTextSecondaryBrush}"/>
                    </Expander.Header>
                    <ItemsControl ItemsSource="{x:Bind ViewModel.ResolvedFindings, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:FindingItemViewModel">
                                <Grid Padding="0,6"
                                      BorderBrush="{ThemeResource AppDividerBrush}"
                                      BorderThickness="0,0,0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="220"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{x:Bind Title}"
                                               FontSize="12"
                                               Foreground="{ThemeResource AppTextSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind Location}"
                                               FontFamily="Cascadia Mono, Consolas"
                                               FontSize="11"
                                               Foreground="{ThemeResource AppTextSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Expander>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
