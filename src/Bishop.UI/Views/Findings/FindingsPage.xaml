<Page
    x:Class="Bishop.UI.Views.Findings.FindingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Bishop.ViewModels.Findings">

    <Page.Resources>
        <CollectionViewSource x:Name="FindingsView"
                              x:Key="FindingsView"
                              Source="{x:Bind ViewModel.Findings, Mode=OneWay}"
                              IsSourceGrouped="False"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header bar -->
        <Grid Grid.Row="0"
              Padding="16,12,16,8"
              BorderBrush="{ThemeResource AppDividerBrush}"
              BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Click="BackButton_Click"
                    Padding="6,2"
                    Margin="0,0,12,0"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE72B;" FontSize="12"/>
                    <TextBlock Text="Back" FontSize="12"/>
                </StackPanel>
            </Button>

            <TextBlock Grid.Column="1"
                       Text="{x:Bind ViewModel.Header, Mode=OneWay}"
                       Style="{ThemeResource SubtitleTextBlockStyle}"
                       VerticalAlignment="Center"/>

            <TextBox Grid.Column="2"
                     PlaceholderText="filter…"
                     Width="220"
                     FontSize="12"
                     Text="{x:Bind ViewModel.FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>

        <!-- Column headers -->
        <Grid Grid.Row="1"
              Padding="16,8,16,8"
              BorderBrush="{ThemeResource AppDividerBrush}"
              BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Click="SortBySeverity_Click"
                    Background="Transparent" BorderThickness="0" Padding="0">
                <TextBlock Text="Severity"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource AppTextSecondaryBrush}"/>
            </Button>
            <Button Grid.Column="1" Click="SortByTitle_Click"
                    Background="Transparent" BorderThickness="0" Padding="0"
                    HorizontalAlignment="Left">
                <TextBlock Text="Title"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource AppTextSecondaryBrush}"/>
            </Button>
            <Button Grid.Column="2" Click="SortByLocation_Click"
                    Background="Transparent" BorderThickness="0" Padding="0"
                    HorizontalAlignment="Left">
                <TextBlock Text="Location"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource AppTextSecondaryBrush}"/>
            </Button>
            <TextBlock Grid.Column="3" Text="Status"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource AppTextSecondaryBrush}"/>
            <TextBlock Grid.Column="4" Text="Action"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource AppTextSecondaryBrush}"/>
        </Grid>

        <!-- Empty-state -->
        <TextBlock Grid.Row="2"
                   Text="No findings."
                   Margin="16,24,16,0"
                   Foreground="{ThemeResource AppTextSecondaryBrush}"
                   Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- Findings rows -->
        <ListView Grid.Row="3"
                  x:Name="FindingsList"
                  ItemsSource="{Binding Source={StaticResource FindingsView}}"
                  SelectionMode="None">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:FindingItemViewModel">
                    <Grid Padding="16,8"
                          BorderBrush="{ThemeResource AppDividerBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>

                        <!-- Severity chip -->
                        <Border Grid.Column="0"
                                Background="{x:Bind SeverityColor, Converter={StaticResource HexColorToBrushConverter}}"
                                CornerRadius="10"
                                Padding="6,1"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Visibility="{x:Bind HasSeverity, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="{x:Bind Severity}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{x:Bind SeverityColor, Converter={StaticResource HexColorToContrastForegroundConverter}}"/>
                        </Border>

                        <!-- Title + expandable body -->
                        <Expander Grid.Column="1"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  HorizontalContentAlignment="Stretch"
                                  HorizontalAlignment="Stretch"
                                  Padding="0">
                            <Expander.Header>
                                <TextBlock Text="{x:Bind Title}"
                                           FontSize="13"
                                           TextWrapping="Wrap"/>
                            </Expander.Header>
                            <TextBlock Text="{x:Bind Body}"
                                       FontFamily="Cascadia Mono, Consolas"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource AppTextSecondaryBrush}"/>
                        </Expander>

                        <!-- Location -->
                        <TextBlock Grid.Column="2"
                                   Text="{x:Bind Location}"
                                   FontFamily="Cascadia Mono, Consolas"
                                   FontSize="12"
                                   Foreground="{ThemeResource AppTextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>

                        <!-- Status -->
                        <TextBlock Grid.Column="3"
                                   Text="{x:Bind StatusLabel, Mode=OneWay}"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>

                        <!-- Convert to card -->
                        <Button Grid.Column="4"
                                Content="Convert to card"
                                FontSize="12"
                                Padding="8,4"
                                Click="ConvertToCard_Click"
                                IsEnabled="{x:Bind IsConvertToCardEnabled, Mode=OneWay}"
                                VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
