<ContentDialog
    x:Class="Bishop.UI.Views.Skills.SkillStageDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Stage skill input"
    PrimaryButtonText="Run"
    CloseButtonText="Cancel"
    DefaultButton="Primary">
    <ContentDialog.Resources>
        <SolidColorBrush x:Key="ContentDialogBackground" Color="#14141A"/>
    </ContentDialog.Resources>
    <StackPanel Spacing="6" MinWidth="420">
        <TextBlock x:Name="PromptText"
                   Style="{StaticResource CaptionTextBlockStyle}"
                   TextWrapping="Wrap"/>
        <ComboBox x:Name="ProjectsCombo"
                  Visibility="Collapsed"
                  HorizontalAlignment="Stretch"
                  PlaceholderText="Project"
                  SelectionChanged="ProjectsCombo_SelectionChanged"/>
        <Button x:Name="FilePickerButton"
                Content="Browse&#x2026;"
                Visibility="Collapsed"
                Click="FilePickerButton_Click"/>
        <TextBox x:Name="InputBox"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 MinHeight="60"
                 MaxHeight="160"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
    </StackPanel>
</ContentDialog>
