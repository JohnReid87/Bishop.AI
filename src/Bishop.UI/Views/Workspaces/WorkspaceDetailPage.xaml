<Page
    x:Class="Bishop.UI.Views.Workspaces.WorkspaceDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Bishop.UI.Views.Controls"
    xmlns:vmCards="using:Bishop.ViewModels.Cards"
    xmlns:vmBatches="using:Bishop.ViewModels.Batches"
    xmlns:vmWorkspaces="using:Bishop.ViewModels.Workspaces"
    xmlns:vmSkills="using:Bishop.ViewModels.Skills"
    xmlns:skills="using:Bishop.App.Skills"
    xmlns:communityControls="using:CommunityToolkit.WinUI.Controls">
    <Page.Resources>
        <DataTemplate x:Key="CardItemTemplate" x:DataType="vmCards:CardViewModel">
            <Grid Margin="8,0,8,4"
                  Opacity="{x:Bind CardOpacity, Mode=OneWay}"
                  Tag="{x:Bind}"
                  Loaded="CardRoot_Loaded">
                <Border Background="{StaticResource AppCardBackgroundBrush}"
                        CornerRadius="4">
                <StackPanel>
                    <controls:SizeAllCursorGrid Padding="{x:Bind IsDoneLane, Converter={StaticResource BoolToThicknessConverter}, ConverterParameter='10,2,4,2|10,4,4,4'}"
                                             Background="Transparent"
                                             BorderBrush="{StaticResource AppDividerBrush}"
                                             BorderThickness="0,0,0,1"
                                             CanDrag="True"
                                             DragStarting="Card_DragStarting"
                                             DropCompleted="Card_DropCompleted">
                        <controls:SizeAllCursorGrid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </controls:SizeAllCursorGrid.ColumnDefinitions>
                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    Spacing="6"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind NumberDisplay}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{StaticResource AppTextTertiaryBrush}"
                                       FontFamily="Cascadia Mono"
                                       VerticalAlignment="Center"/>
                            <controls:HandCursorButton Background="Transparent"
                                                   BorderThickness="0"
                                                   Padding="0"
                                                   MinWidth="0"
                                                   MinHeight="0"
                                                   Click="CardTagChip_Click"
                                                   ToolTipService.ToolTip="Change tag"
                                                   Visibility="{x:Bind IsTagVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                                   VerticalAlignment="Center">
                                <Border Background="{x:Bind TagColour, Converter={StaticResource HexColorToBrushConverter}}"
                                        CornerRadius="3"
                                        Padding="5,1">
                                    <TextBlock Text="{x:Bind TagName}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{x:Bind TagColour, Converter={StaticResource HexColorToContrastForegroundConverter}}"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </controls:HandCursorButton>
                            <controls:HandCursorButton Click="CardAddTagButton_Click"
                                                   Visibility="{x:Bind IsAddTagButtonVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                                   Padding="5,1"
                                                   BorderThickness="0"
                                                   CornerRadius="3"
                                                   Background="{StaticResource AppDividerBrush}">
                                <TextBlock Text="+ tag"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           VerticalAlignment="Center"/>
                            </controls:HandCursorButton>
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal">
                            <FontIcon Glyph="&#xE99A;"
                                      Foreground="#ff5555"
                                      FontSize="12"
                                      VerticalAlignment="Center"
                                      Margin="0,0,4,0"
                                      ToolTipService.ToolTip="{x:Bind AutoRunFailedTooltip}"
                                      Visibility="{x:Bind IsAutoRunFailedIndicatorVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <FontIcon Glyph="&#xE99A;"
                                      Foreground="#00ff41"
                                      FontSize="12"
                                      VerticalAlignment="Center"
                                      Margin="0,0,4,0"
                                      ToolTipService.ToolTip="{x:Bind AutoRunSucceededTooltip}"
                                      Visibility="{x:Bind IsAutoRunSucceededIndicatorVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <controls:HandCursorButton Style="{StaticResource DateTimePickerFlyoutButtonStyle}"
                                                   ToolTipService.ToolTip="Skills"
                                                   Click="CardSkillsButton_Click"
                                                   Visibility="{x:Bind IsSkillsButtonVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                                   VerticalAlignment="Center"
                                                   Padding="4"
                                                   MinWidth="28"
                                                   MinHeight="28">
                                <FontIcon Glyph="&#xEBD2;" FontSize="12"/>
                            </controls:HandCursorButton>
                            <controls:HandCursorButton Style="{StaticResource DateTimePickerFlyoutButtonStyle}"
                                                   ToolTipService.ToolTip="{x:Bind CloseReopenTooltip, Mode=OneWay}"
                                                   Click="CardCloseButton_Click"
                                                   VerticalAlignment="Center"
                                                   Padding="4"
                                                   MinWidth="28"
                                                   MinHeight="28">
                                <FontIcon Glyph="{x:Bind CloseReopenGlyph, Mode=OneWay}" FontSize="12"/>
                            </controls:HandCursorButton>
                        </StackPanel>
                    </controls:SizeAllCursorGrid>
                    <controls:HandCursorGrid>
                        <TextBlock Text="{x:Bind Title}"
                                   TextWrapping="Wrap"
                                   Padding="{x:Bind IsDoneLane, Converter={StaticResource BoolToThicknessConverter}, ConverterParameter='10,3,10,4|10,6,10,8'}"
                                   FontSize="{x:Bind CardTitleFontSize}"
                                   Tapped="CardTitle_Tapped"/>
                    </controls:HandCursorGrid>
                </StackPanel>
                </Border>
                <Border CornerRadius="4"
                        IsHitTestVisible="False"
                        BorderBrush="{StaticResource AppCardSelectionBorderBrush}"
                        BorderThickness="2"
                        Background="{StaticResource AppCardSelectionBrush}"
                        Visibility="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <Border CornerRadius="4"
                        IsHitTestVisible="False"
                        BorderBrush="#5da75d"
                        BorderThickness="1"
                        Visibility="{x:Bind IsInProgress, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="CompactCardItemTemplate" x:DataType="vmCards:CardViewModel">
            <Grid Margin="4,0,4,4" Opacity="{x:Bind CardOpacity, Mode=OneWay}" Tag="{x:Bind}" RightTapped="CompactCard_RightTapped" Loaded="CardRoot_Loaded">
                <Border Background="{StaticResource AppCardBackgroundBrush}"
                        CornerRadius="4"
                        BorderBrush="#cc4444"
                        BorderThickness="{x:Bind IsAutoRunFailedIndicatorVisible, Converter={StaticResource BoolToThicknessConverter}, ConverterParameter='1.5|0'}">
                    <StackPanel Padding="8,6">
                        <TextBlock Text="{x:Bind Title}"
                                   MaxLines="2"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="Wrap"
                                   FontSize="12"/>
                        <StackPanel Orientation="Horizontal"
                                    Spacing="6"
                                    Margin="0,4,0,0">
                            <Ellipse Width="8"
                                     Height="8"
                                     Fill="{x:Bind LaneDotColour, Converter={StaticResource HexColorToBrushConverter}}"
                                     VerticalAlignment="Center"/>
                            <Border Background="{x:Bind TagColour, Converter={StaticResource HexColorToBrushConverter}}"
                                    CornerRadius="3"
                                    Padding="5,1"
                                    Visibility="{x:Bind IsTagVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="{x:Bind TagName}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{x:Bind TagColour, Converter={StaticResource HexColorToContrastForegroundConverter}}"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="BatchGroupItemTemplate" x:DataType="vmBatches:BatchGroupViewModel">
            <Grid Margin="8,0,8,4">
                <Border Background="{StaticResource AppCardBackgroundBrush}"
                        BorderBrush="{StaticResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="0"
                                   Fill="{x:Bind AccentColor, Converter={StaticResource HexColorToBrushConverter}}"/>
                        <Expander Grid.Column="1"
                                  IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Padding="0">
                            <Expander.Header>
                                <Grid HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{x:Bind BatchName, Mode=OneWay}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{StaticResource AppTextSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind ProgressDisplay, Mode=OneWay}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{StaticResource AppTextTertiaryBrush}"
                                               FontFamily="Cascadia Mono"
                                               VerticalAlignment="Center"
                                               Margin="4,0,4,0"/>
                                </Grid>
                            </Expander.Header>
                            <ItemsRepeater ItemsSource="{x:Bind Cards, Mode=OneWay}"
                                           ItemTemplate="{StaticResource CardItemTemplate}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Orientation="Vertical"/>
                                </ItemsRepeater.Layout>
                            </ItemsRepeater>
                        </Expander>
                    </Grid>
                </Border>
            </Grid>
        </DataTemplate>

        <controls:CardOrGroupTemplateSelector x:Key="CardOrGroupSelector"
                                            CardTemplate="{StaticResource CardItemTemplate}"
                                            GroupTemplate="{StaticResource BatchGroupItemTemplate}"/>
    </Page.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Compact header bar -->
        <Grid Grid.Row="0" Padding="16,0"
              MinHeight="48"
              BorderBrush="{StaticResource AppDividerBrush}"
              BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="1">
                <TextBlock x:Name="WorkspaceNameText"
                           Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <TextBlock x:Name="WorkspacePathText"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{StaticResource AppTextSecondaryBrush}"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <!-- Search box with custom-coloured fake placeholder -->
            <Grid Grid.Column="1" VerticalAlignment="Center" Margin="8,0" Width="150">
                <TextBox x:Name="CardSearchBox"
                         Text="{x:Bind Board.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         MinHeight="0"
                         PreviewKeyDown="CardSearch_PreviewKeyDown">
                    <TextBox.Resources>
                        <Thickness x:Key="TextControlThemePadding">10,4,10,4</Thickness>
                    </TextBox.Resources>
                </TextBox>
                <TextBlock Text="Search cards…"
                           Foreground="#44FFFFFF"
                           VerticalAlignment="Center"
                           Margin="11,0,0,0"
                           IsHitTestVisible="False"
                           Visibility="{x:Bind Board.IsSearchEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>

            <StackPanel x:Name="LaunchButtonWrapper"
                        Grid.Column="2"
                        Orientation="Horizontal"
                        Spacing="4"
                        VerticalAlignment="Center"
                        Margin="16,0,0,0">
                <Button x:Name="WorkspaceSkillsButton"
                        Padding="8,4"
                        Visibility="Collapsed"
                        Click="WorkspaceSkillsButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xEBD2;" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text="Skills" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="CommitsButton"
                        Padding="8,4"
                        Click="CommitsButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE81C;" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text="Commits" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="GitButton"
                        Padding="8,4"
                        Visibility="{x:Bind Git.IsGitRepo, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        Click="GitButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE71D;" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text="Git" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="TerminalButton"
                        Padding="8,4"
                        Click="TerminalButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8A7;" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text="Terminal" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="ClaudeButton"
                        Padding="8,4"
                        Click="ClaudeButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE768;" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text="Claude" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Content area -->
        <Grid Grid.Row="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

            <!-- Board + Monitoring tabs -->
            <TabView x:Name="MainTabView"
                     Grid.Row="0"
                     IsAddTabButtonVisible="False"
                     CanDragTabs="False"
                     CanReorderTabs="False"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Stretch">

                <TabViewItem Header="Board" IsClosable="False">
                    <TabViewItem.Content>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                        <!-- Notification bars — collapsed when no InfoBar is open -->
                        <StackPanel x:Name="NotificationPanel"
                                    Grid.Row="0"
                                    Padding="16,12,16,0"
                                    Spacing="8"
                                    Visibility="Collapsed">
                <InfoBar x:Name="PathWarningBar"
                         IsOpen="False"
                         IsClosable="False"
                         Severity="Warning"
                         Title="Directory not found"
                         Message="The workspace directory is missing. Right-click the workspace and choose Repath to locate it."/>
                <InfoBar x:Name="FallbackWarningBar"
                         IsOpen="False"
                         IsClosable="True"
                         Severity="Informational"
                         Title="Windows Terminal not detected"
                         Message="PowerShell opened instead — claude was not auto-started. If Windows Terminal is installed, enable its app execution alias in Settings → Apps → Advanced app settings → App execution aliases."
                         Closed="InfoBar_Closed">
                    <InfoBar.ActionButton>
                        <HyperlinkButton Content="Get Windows Terminal"
                                         NavigateUri="https://aka.ms/terminal"/>
                    </InfoBar.ActionButton>
                </InfoBar>
                <InfoBar x:Name="CopiedBar"
                         IsOpen="False"
                         IsClosable="False"
                         Severity="Success"
                         Title="Copied to clipboard"/>
            </StackPanel>

            <!-- Kanban lanes -->
            <ListView x:Name="LanesListView"
                      Grid.Row="1"
                      ItemsSource="{x:Bind Board.Lanes}"
                      SelectionMode="None"
                      Padding="8,4,0,12"
                      ScrollViewer.HorizontalScrollMode="Enabled"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollMode="Disabled"
                      ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsStackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,8,0"/>
                            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vmWorkspaces:LaneViewModel">
                            <Grid Width="220"
                                  VerticalAlignment="Stretch"
                                  Background="{StaticResource AppLaneBackgroundBrush}"
                                  CornerRadius="8"
                                  Padding="0,0,0,8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{x:Bind DisplayName, Mode=OneWay}"
                                               Style="{StaticResource BodyStrongTextBlockStyle}"
                                               Padding="12,10,12,8"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Style="{StaticResource DateTimePickerFlyoutButtonStyle}"
                                                Command="{x:Bind BeginAddCardCommand}"
                                                Click="BeginAddCard_Click"
                                                Margin="0,0,8,0"
                                                ToolTipService.ToolTip="Add card">
                                            <FontIcon Glyph="&#xE710;" FontSize="12"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <Grid Grid.Row="1"
                                      AllowDrop="True"
                                      DragOver="Cards_DragOver"
                                      DragLeave="Cards_DragLeave"
                                      Drop="Cards_Drop">
                                    <ScrollViewer VerticalScrollMode="Auto"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollMode="Disabled"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  AllowDrop="True">
                                        <StackPanel>
                                            <!-- Add card input -->
                                            <StackPanel Spacing="4"
                                                        Margin="8,4,8,4"
                                                        Visibility="{x:Bind IsAddingCard, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBox PlaceholderText="Card title"
                                                         Text="{x:Bind NewCardTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         PreviewKeyDown="AddCardTextBox_PreviewKeyDown"/>
                                                <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right">
                                                    <Button Content="&#x2713;"
                                                            Command="{x:Bind ConfirmAddCardCommand}"
                                                            ToolTipService.ToolTip="Add card (Enter)"/>
                                                    <Button Content="&#x2715;"
                                                            Command="{x:Bind CancelAddCardCommand}"
                                                            ToolTipService.ToolTip="Cancel (Escape)"/>
                                                </StackPanel>
                                                <TextBlock Text="{x:Bind AddCardErrorMessage, Mode=OneWay}"
                                                           Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                                           TextWrapping="Wrap"
                                                           FontSize="12"
                                                           Visibility="{x:Bind HasAddCardError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            </StackPanel>

                                            <!-- Card list (with batch grouping) -->
                                            <ItemsRepeater ItemsSource="{x:Bind LaneItems, Mode=OneWay}"
                                                           ItemTemplate="{StaticResource CardOrGroupSelector}">
                                                <ItemsRepeater.Layout>
                                                    <StackLayout Orientation="Vertical"/>
                                                </ItemsRepeater.Layout>
                                            </ItemsRepeater>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>


<!-- Drag-target highlight overlay -->
                                <Border Grid.RowSpan="2"
                                        IsHitTestVisible="False"
                                        CornerRadius="8"
                                        BorderBrush="{StaticResource AppDragTargetBorderBrush}"
                                        BorderThickness="2"
                                        Background="{StaticResource AppDragTargetBrush}"
                                        Visibility="{x:Bind IsDropTarget, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Batch staging tray -->
                <Border Grid.Row="2"
                        BorderBrush="{StaticResource AppDividerBrush}"
                        BorderThickness="0,1,0,0"
                        Background="{StaticResource AppLaneBackgroundBrush}"
                        Padding="16,10"
                        Visibility="{x:Bind Board.StagingTray.IsVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Spacing="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                       VerticalAlignment="Center"
                                       Text="New batch"/>
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        VerticalAlignment="Center">
                                <Button x:Name="StagingTrayCancelButton"
                                        Content="Cancel"
                                        Padding="12,4"
                                        Click="StagingTrayCancel_Click"/>
                                <Button x:Name="StagingTrayCreateButton"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Padding="12,4"
                                        Content="{x:Bind Board.StagingTray.CreateLabel, Mode=OneWay}"
                                        IsEnabled="{x:Bind Board.StagingTray.CanCreate, Mode=OneWay}"
                                        Click="StagingTrayCreate_Click"/>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="Name"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                <TextBox x:Name="StagingTrayNameBox"
                                         Text="{x:Bind Board.StagingTray.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="Batch name"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Text="Branch"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                <TextBox x:Name="StagingTrayBranchBox"
                                         Text="{x:Bind Board.StagingTray.Branch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="bishop/&lt;slug&gt;"
                                         FontFamily="Cascadia Mono"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="2">
                                <TextBlock Text="Model"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                <ComboBox x:Name="StagingTrayModelBox"
                                          ItemsSource="{x:Bind Board.StagingTray.Models}"
                                          SelectedValue="{x:Bind Board.StagingTray.Model, Mode=TwoWay}"
                                          SelectedValuePath="Id"
                                          DisplayMemberPath="Label"
                                          HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" Spacing="2" VerticalAlignment="Bottom">
                                <TextBlock Text="Base"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind Board.StagingTray.BaseBranch, Mode=OneWay}"
                                           FontFamily="Cascadia Mono"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"
                                           Margin="0,6,0,6"/>
                            </StackPanel>
                        </Grid>

                        <ItemsRepeater ItemsSource="{x:Bind Board.StagingTray.Cards}">
                            <ItemsRepeater.Layout>
                                <UniformGridLayout MinItemWidth="220"
                                                   MinItemHeight="28"
                                                   MinColumnSpacing="6"
                                                   MinRowSpacing="6"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vmCards:CardViewModel">
                                    <Border Background="{StaticResource AppCardBackgroundBrush}"
                                            CornerRadius="3"
                                            Padding="6,2"
                                            Tag="{x:Bind}">
                                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind NumberDisplay}"
                                                       FontFamily="Cascadia Mono"
                                                       FontSize="11"
                                                       Foreground="{StaticResource AppTextTertiaryBrush}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{x:Bind Title}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="180"
                                                       VerticalAlignment="Center"/>
                                            <Button Content="&#x2715;"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Padding="2,0"
                                                    MinWidth="0"
                                                    MinHeight="0"
                                                    FontSize="11"
                                                    Click="StagingTrayRemoveChip_Click"
                                                    ToolTipService.ToolTip="Remove from batch"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </Border>

                        </Grid>
                    </TabViewItem.Content>
                </TabViewItem>

                <TabViewItem IsClosable="False">
                    <TabViewItem.Header>
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="Monitoring" VerticalAlignment="Center"/>
                            <Grid MinWidth="16" MinHeight="16"
                                  Visibility="{x:Bind Monitoring.BadgeIsVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                  ToolTipService.ToolTip="{x:Bind Monitoring.BadgeTooltip, Mode=OneWay}">
                                <Rectangle RadiusX="8" RadiusY="8"
                                           Fill="{x:Bind Monitoring.BadgeColor, Mode=OneWay, Converter={StaticResource HexColorToBrushConverter}}"/>
                                <TextBlock Text="{x:Bind Monitoring.BadgeCount, Mode=OneWay}"
                                           Foreground="{x:Bind Monitoring.BadgeColor, Mode=OneWay, Converter={StaticResource HexColorToContrastForegroundConverter}}"
                                           FontSize="11"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="6,1"/>
                            </Grid>
                        </StackPanel>
                    </TabViewItem.Header>
                    <TabViewItem.Content>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Table header -->
                            <Grid Grid.Row="0"
                                  Padding="16,12,16,8"
                                  BorderBrush="{StaticResource AppDividerBrush}"
                                  BorderThickness="0,0,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Skill"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="Last run"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                <TextBlock Grid.Column="2" Text="Commits since"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                <TextBlock Grid.Column="3" Text="Findings"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                <TextBlock Grid.Column="4" Text="Status"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                            </Grid>

                            <!-- Skill run rows -->
                            <ListView Grid.Row="1"
                                      ItemsSource="{x:Bind Monitoring.Rows}"
                                      SelectedItem="{x:Bind Monitoring.SelectedRow, Mode=TwoWay}"
                                      SelectionMode="Single"
                                      Padding="0,4,0,12">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vmSkills:SkillRunRowViewModel">
                                        <Grid Padding="16,8"
                                              BorderBrush="{StaticResource AppDividerBrush}"
                                              BorderThickness="0,0,0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="160"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{x:Bind DisplayLabel}"
                                                       FontFamily="Cascadia Mono"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{x:Bind LastRunText}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{x:Bind CommitsSinceText}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="3"
                                                        Orientation="Horizontal"
                                                        Spacing="4"
                                                        VerticalAlignment="Center">
                                                <Button Content="{x:Bind FindingsButtonText}"
                                                        FontSize="12"
                                                        Padding="8,4"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        Command="{x:Bind ViewFindingsCommand}"
                                                        Visibility="{x:Bind CanViewFindings, Converter={StaticResource BoolToVisibilityConverter}}"
                                                        ToolTipService.ToolTip="View findings from last run"/>
                                                <Button Content="View report"
                                                        FontSize="12"
                                                        Padding="8,4"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        Command="{x:Bind ViewReportCommand}"
                                                        Visibility="{x:Bind CanViewReport, Converter={StaticResource BoolToVisibilityConverter}}"
                                                        ToolTipService.ToolTip="Open coverage report"/>
                                            </StackPanel>
                                            <Ellipse Grid.Column="4"
                                                     Width="10"
                                                     Height="10"
                                                     Fill="{x:Bind StatusDotColor, Converter={StaticResource HexColorToBrushConverter}}"
                                                     VerticalAlignment="Center"
                                                     ToolTipService.ToolTip="{x:Bind StatusTooltip}"/>
                                            <StackPanel Grid.Column="5"
                                                        Orientation="Horizontal"
                                                        Spacing="6"
                                                        VerticalAlignment="Center">
                                                <Button Content="{x:Bind SelectedModelLabel, Mode=OneWay}"
                                                        Width="100"
                                                        Padding="8,4"
                                                        FontSize="12"
                                                        VerticalAlignment="Center">
                                                    <Button.Flyout>
                                                        <MenuFlyout>
                                                            <MenuFlyoutItem Text="{x:Bind skills:ClaudeModels.Opus48Display}"
                                                                            Command="{x:Bind SelectModelCommand}"
                                                                            CommandParameter="{x:Bind skills:ClaudeModels.Opus48}"/>
                                                            <MenuFlyoutItem Text="{x:Bind skills:ClaudeModels.Opus47Display}"
                                                                            Command="{x:Bind SelectModelCommand}"
                                                                            CommandParameter="{x:Bind skills:ClaudeModels.Opus47}"/>
                                                            <MenuFlyoutItem Text="{x:Bind skills:ClaudeModels.Sonnet46Display}"
                                                                            Command="{x:Bind SelectModelCommand}"
                                                                            CommandParameter="{x:Bind skills:ClaudeModels.Sonnet46}"/>
                                                            <MenuFlyoutItem Text="{x:Bind skills:ClaudeModels.Haiku45Display}"
                                                                            Command="{x:Bind SelectModelCommand}"
                                                                            CommandParameter="{x:Bind skills:ClaudeModels.Haiku45}"/>
                                                        </MenuFlyout>
                                                    </Button.Flyout>
                                                </Button>
                                                <Button Content="Run now"
                                                        Padding="8,4"
                                                        FontSize="12"
                                                        Click="RunNowSkillButton_Click"
                                                        VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                        </Grid>
                    </TabViewItem.Content>
                </TabViewItem>

                <TabViewItem IsClosable="False">
                    <TabViewItem.Header>
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="Batches" VerticalAlignment="Center"/>
                            <Grid MinWidth="16" MinHeight="16"
                                  Visibility="{x:Bind Batches.BadgeIsVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                  ToolTipService.ToolTip="{x:Bind Batches.BadgeTooltip, Mode=OneWay}">
                                <Rectangle RadiusX="8" RadiusY="8"
                                           Fill="{x:Bind Batches.BadgeColor, Mode=OneWay, Converter={StaticResource HexColorToBrushConverter}}"/>
                                <TextBlock Text="{x:Bind Batches.BadgeCount, Mode=OneWay}"
                                           Foreground="{x:Bind Batches.BadgeColor, Mode=OneWay, Converter={StaticResource HexColorToContrastForegroundConverter}}"
                                           FontSize="11"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="6,1"/>
                            </Grid>
                            <Button x:Name="ClearClosedBatchesButton"
                                    Padding="6,2"
                                    FontSize="11"
                                    Click="ClearClosedBatches_Click"
                                    Visibility="{x:Bind Batches.HasClosedBatches, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                    ToolTipService.ToolTip="Remove all closed batch records; cards stay on the board">
                                <TextBlock Text="Clear closed batches" VerticalAlignment="Center"/>
                            </Button>
                        </StackPanel>
                    </TabViewItem.Header>
                    <TabViewItem.Content>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Table header -->
                            <Grid Grid.Row="0"
                                  Padding="16,12,16,8"
                                  BorderBrush="{StaticResource AppDividerBrush}"
                                  BorderThickness="0,0,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="1" Text="Name"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                <TextBlock Grid.Column="2" Text="Branch"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                <TextBlock Grid.Column="3" Text="Status"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                <TextBlock Grid.Column="4" Text="Cards"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                            </Grid>

                            <!-- Batch rows -->
                            <Grid Grid.Row="1">
                                <TextBlock Text="No batches."
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"
                                           Visibility="{x:Bind Batches.HasBatches, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                                <ListView ItemsSource="{x:Bind Batches.Batches}"
                                          SelectionMode="None"
                                          Padding="0,4,0,12"
                                          Visibility="{x:Bind Batches.HasBatches, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="vmBatches:BatchItemViewModel">
                                            <Grid BorderBrush="{StaticResource AppDividerBrush}"
                                                  BorderThickness="0,0,0,1">
                                                <Expander IsExpanded="{x:Bind IsStripExpanded, Mode=TwoWay}"
                                                          HorizontalAlignment="Stretch"
                                                          HorizontalContentAlignment="Stretch"
                                                          Background="Transparent"
                                                          BorderThickness="0"
                                                          Padding="0">
                                                    <Expander.Header>
                                                <!-- Batch info row -->
                                                <Grid Padding="0,4,0,4"
                                                      HorizontalAlignment="Stretch">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="180"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="70"/>
                                                        <ColumnDefinition Width="60"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               x:Name="BatchNameTextBlock"
                                                               Text="{x:Bind Name, Mode=OneWay}"
                                                               FontSize="12"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"
                                                               Visibility="{x:Bind IsNameEditing, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                                               Tapped="BatchNameTextBlock_Tapped"/>
                                                    <TextBox Grid.Column="0"
                                                             x:Name="BatchNameTextBox"
                                                             FontSize="12"
                                                             VerticalAlignment="Center"
                                                             Padding="4,2"
                                                             Visibility="{x:Bind IsNameEditing, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                                             KeyDown="BatchNameTextBox_KeyDown"
                                                             LostFocus="BatchNameTextBox_LostFocus"/>
                                                    <StackPanel Grid.Column="1"
                                                                VerticalAlignment="Center"
                                                                Spacing="2">
                                                        <TextBlock Text="{x:Bind BranchName}"
                                                                   FontFamily="Cascadia Mono"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource AppTextSecondaryBrush}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <StackPanel Orientation="Horizontal"
                                                                    Spacing="8">
                                                            <StackPanel Orientation="Horizontal"
                                                                        Spacing="2"
                                                                        ToolTipService.ToolTip="Merged into base branch">
                                                                <FontIcon Glyph="&#xE73E;"
                                                                          FontSize="12"
                                                                          Foreground="{x:Bind IsMergedColor, Converter={StaticResource HexColorToBrushConverter}}"/>
                                                                <TextBlock Text="merged"
                                                                           FontSize="11"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="{x:Bind IsMergedColor, Converter={StaticResource HexColorToBrushConverter}}"/>
                                                            </StackPanel>
                                                            <StackPanel Orientation="Horizontal"
                                                                        Spacing="2"
                                                                        ToolTipService.ToolTip="Branch exists locally">
                                                                <FontIcon Glyph="&#xE943;"
                                                                          FontSize="12"
                                                                          Foreground="{x:Bind BranchExistsColor, Converter={StaticResource HexColorToBrushConverter}}"/>
                                                                <TextBlock Text="branch"
                                                                           FontSize="11"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="{x:Bind BranchExistsColor, Converter={StaticResource HexColorToBrushConverter}}"/>
                                                            </StackPanel>
                                                            <StackPanel Orientation="Horizontal"
                                                                        Spacing="2"
                                                                        ToolTipService.ToolTip="Worktree exists">
                                                                <FontIcon Glyph="&#xE8B7;"
                                                                          FontSize="12"
                                                                          Foreground="{x:Bind WorktreeExistsColor, Converter={StaticResource HexColorToBrushConverter}}"/>
                                                                <TextBlock Text="worktree"
                                                                           FontSize="11"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="{x:Bind WorktreeExistsColor, Converter={StaticResource HexColorToBrushConverter}}"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2"
                                                               Text="{x:Bind StatusLabel}"
                                                               FontSize="12"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="3"
                                                               Text="{x:Bind CardCountLabel}"
                                                               FontSize="12"
                                                               VerticalAlignment="Center"
                                                               Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                                    <StackPanel Grid.Column="4"
                                                                Orientation="Horizontal"
                                                                Spacing="6"
                                                                VerticalAlignment="Center">
                                                        <Button Content="Run"
                                                                Padding="8,4"
                                                                FontSize="12"
                                                                Click="BatchRun_Click"
                                                                Visibility="{x:Bind CanRun, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                ToolTipService.ToolTip="Launch batch run in terminal"/>
                                                        <Button Content="Resume"
                                                                Padding="8,4"
                                                                FontSize="12"
                                                                Click="BatchResume_Click"
                                                                Visibility="{x:Bind CanResume, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                ToolTipService.ToolTip="Resume batch run from the next undone card"/>
                                                        <Button Content="Pause"
                                                                Padding="8,4"
                                                                FontSize="12"
                                                                Click="BatchPause_Click"
                                                                Visibility="{x:Bind CanPause, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                ToolTipService.ToolTip="Request batch pause after the current card completes"/>
                                                        <Button Content="Merge"
                                                                Padding="8,4"
                                                                FontSize="12"
                                                                Click="BatchMerge_Click"
                                                                Visibility="{x:Bind CanMerge, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                ToolTipService.ToolTip="Merge batch branch into base with --no-ff"/>
                                                        <Button Content="Clean up"
                                                                Padding="8,4"
                                                                FontSize="12"
                                                                Click="BatchCleanUp_Click"
                                                                Visibility="{x:Bind CanCleanUp, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                ToolTipService.ToolTip="Remove worktree, delete branch, and close batch"/>
                                                        <Button Content="Abandon"
                                                                Padding="8,4"
                                                                FontSize="12"
                                                                Click="BatchAbandon_Click"
                                                                Visibility="{x:Bind CanAbandon, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                ToolTipService.ToolTip="Restore cards to To Do and remove the batch's worktree"/>
                                                        <Button Content="Remove"
                                                                Padding="8,4"
                                                                FontSize="12"
                                                                Click="BatchRemove_Click"
                                                                Visibility="{x:Bind CanRemove, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                ToolTipService.ToolTip="Delete batch record; cards stay on the board"/>
                                                    </StackPanel>
                                                </Grid>
                                                    </Expander.Header>

                                                    <!-- Card strip -->
                                                    <Grid Opacity="{x:Bind StripOpacity}">
                                                        <TextBlock Text="No cards in this batch."
                                                                   Margin="0,4,16,4"
                                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                                   Foreground="{StaticResource AppTextTertiaryBrush}"
                                                                   Visibility="{x:Bind IsStripEmpty, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                        <ItemsRepeater ItemsSource="{x:Bind Cards, Mode=OneWay}"
                                                                       Margin="0,4,8,4"
                                                                       Visibility="{x:Bind IsStripEmpty, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                                            <ItemsRepeater.Layout>
                                                                <UniformGridLayout MinItemWidth="140"
                                                                                   MinColumnSpacing="0"
                                                                                   MinRowSpacing="0"/>
                                                            </ItemsRepeater.Layout>
                                                            <ItemsRepeater.ItemTemplate>
                                                                <DataTemplate x:DataType="vmCards:CardViewModel">
                                                                    <ContentPresenter Content="{x:Bind}"
                                                                                      ContentTemplate="{StaticResource CompactCardItemTemplate}"/>
                                                                </DataTemplate>
                                                            </ItemsRepeater.ItemTemplate>
                                                        </ItemsRepeater>
                                                    </Grid>
                                                </Expander>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Grid>
                    </TabViewItem.Content>
                </TabViewItem>
            </TabView>

            <!-- Notes panel -->
            <Expander Grid.Row="1"
                      IsExpanded="{x:Bind Notes.IsExpanded, Mode=TwoWay}"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch"
                      Background="Transparent"
                      BorderBrush="{StaticResource AppDividerBrush}"
                      BorderThickness="0,1,0,0"
                      CornerRadius="0"
                      Padding="0"
                      ToolTipService.ToolTip="Ctrl+S to save">
                <Expander.Header>
                    <Grid HorizontalAlignment="Stretch">
                        <TextBlock Text="Notes"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Bind Notes.SaveStatusText, Mode=OneWay}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{StaticResource AppTextSecondaryBrush}"
                                   FontStyle="{x:Bind Notes.SaveStatusIsEditing, Mode=OneWay, Converter={StaticResource BoolToFontStyleConverter}}"
                                   Opacity="{x:Bind Notes.SaveStatusOpacity, Mode=OneWay}"
                                   Visibility="{x:Bind Notes.SaveStatusIsError, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                        <TextBlock Text="{x:Bind Notes.SaveStatusText, Mode=OneWay}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="Red"
                                   Visibility="{x:Bind Notes.SaveStatusIsError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </Grid>
                </Expander.Header>
                <StackPanel HorizontalAlignment="Stretch">
                    <controls:NotesSplitter Height="6"
                                            Background="{StaticResource AppDividerBrush}"
                                            PointerPressed="NotesSplitter_PointerPressed"
                                            PointerMoved="NotesSplitter_PointerMoved"
                                            PointerReleased="NotesSplitter_PointerReleased"
                                            PointerCaptureLost="NotesSplitter_PointerCaptureLost"/>
                    <InfoBar IsOpen="{x:Bind Notes.IsExternalChangeBarVisible, Mode=OneWay}"
                             IsClosable="False"
                             Severity="Warning"
                             Title="File changed externally"
                             Margin="0,8,0,8">
                        <InfoBar.Content>
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,4">
                                <HyperlinkButton Content="Reload"
                                                 Command="{x:Bind Notes.ReloadCommand}"
                                                 Padding="0"/>
                                <TextBlock Text="/"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                <HyperlinkButton Content="Keep my edits"
                                                 Command="{x:Bind Notes.KeepEditsCommand}"
                                                 Padding="0"/>
                            </StackPanel>
                        </InfoBar.Content>
                    </InfoBar>
                    <TextBox x:Name="NotesTextBox"
                             Text="{x:Bind Notes.NotesContent, Mode=TwoWay}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             FontFamily="Cascadia Mono"
                             Height="{x:Bind Notes.PanelHeight, Mode=OneWay}"

                             Margin="0,0,0,8"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             PreviewKeyDown="NotesTextBox_PreviewKeyDown"/>
                </StackPanel>
            </Expander>
            </Grid>

        </Grid>
    </Grid>
</Page>
