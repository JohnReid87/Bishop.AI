<UserControl
    x:Class="Bishop.UI.Views.Workspaces.GitFlyoutControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vmWorkspaces="using:Bishop.ViewModels.Workspaces"
    xmlns:converters="using:Bishop.UI.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
    </UserControl.Resources>
    <StackPanel Spacing="6" Padding="8" Width="420">

        <!-- Static header: Git config -->
        <Grid ColumnSpacing="8" RowSpacing="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Remote -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Remote"
                       FontSize="12" VerticalAlignment="Center"
                       Foreground="{StaticResource AppTextSecondaryBrush}"/>
            <TextBlock Grid.Row="0" Grid.Column="1"
                       Text="{x:Bind Git.Remote, Mode=OneWay}"
                       FontSize="12" VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       TextWrapping="NoWrap">
                <ToolTipService.ToolTip>
                    <TextBlock Text="{x:Bind Git.Remote, Mode=OneWay}" TextWrapping="Wrap" MaxWidth="600"/>
                </ToolTipService.ToolTip>
            </TextBlock>
            <Button Grid.Row="0" Grid.Column="2"
                    x:Name="CopyRemoteButton"
                    Padding="6,2"
                    Click="CopyRemote_Click">
                <FontIcon Glyph="&#xE8C8;" FontSize="12"/>
            </Button>

            <!-- Branch -->
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Branch"
                       FontSize="12" VerticalAlignment="Center"
                       Foreground="{StaticResource AppTextSecondaryBrush}"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                       Text="{x:Bind Git.Branch, Mode=OneWay}"
                       FontSize="12" VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       TextWrapping="NoWrap">
                <ToolTipService.ToolTip>
                    <TextBlock Text="{x:Bind Git.Branch, Mode=OneWay}" TextWrapping="Wrap" MaxWidth="600"/>
                </ToolTipService.ToolTip>
            </TextBlock>

            <!-- Status -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Status"
                       FontSize="12" VerticalAlignment="Center"
                       Foreground="{StaticResource AppTextSecondaryBrush}"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                       Text="{x:Bind Git.Status, Mode=OneWay}"
                       FontSize="12" VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       TextWrapping="NoWrap"/>

            <!-- Identity -->
            <TextBlock Grid.Row="3" Grid.Column="0" Text="Identity"
                       FontSize="12" VerticalAlignment="Center"
                       Foreground="{StaticResource AppTextSecondaryBrush}"/>
            <StackPanel Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="6"
                        VerticalAlignment="Center">
                <TextBlock Text="{x:Bind Git.Identity, Mode=OneWay}"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="NoWrap"/>
                <TextBlock Text="{x:Bind Git.IdentityScope, Mode=OneWay}"
                           FontSize="11"
                           FontStyle="Italic"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
            </StackPanel>
        </Grid>

        <!-- Divider between static header and commits -->
        <Border Height="1" Margin="0,4,0,2"
                Background="{StaticResource AppDividerBrush}"/>

        <!-- Status message (not a git repo, git not found, no commits) -->
        <TextBlock Text="{x:Bind Commits.StatusMessage, Mode=OneWay}"
                   FontSize="12"
                   Padding="4,6,4,6"
                   Visibility="{x:Bind Commits.HasCommits, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

        <!-- Commit rows -->
        <ScrollViewer MaxHeight="400"
                      Visibility="{x:Bind Commits.HasCommits, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <ItemsControl ItemsSource="{x:Bind Commits.Commits, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vmWorkspaces:CommitRowViewModel">
                        <StackPanel>
                            <Button Tag="{x:Bind}"
                                    Click="CommitRow_Click"
                                    HorizontalContentAlignment="Stretch"
                                    HorizontalAlignment="Stretch"
                                    Padding="4,4,4,4">
                                <ToolTipService.ToolTip>
                                    <TextBlock Text="{x:Bind Tooltip}" TextWrapping="Wrap" MaxWidth="600"/>
                                </ToolTipService.ToolTip>
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{x:Bind ShortHash}"
                                               FontFamily="Cascadia Mono, Consolas, Courier New"
                                               FontSize="11"
                                               VerticalAlignment="Center"
                                               Width="56"
                                               Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind Subject}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{x:Bind RelativeTime}"
                                               FontSize="11"
                                               VerticalAlignment="Center"
                                               MinWidth="56"
                                               TextAlignment="Right"
                                               Margin="0,0,4,0"
                                               Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                    <Border Grid.Column="3" Background="Transparent" Padding="2">
                                        <ToolTipService.ToolTip>
                                            <TextBlock Text="{x:Bind IconTooltip}"/>
                                        </ToolTipService.ToolTip>
                                        <Grid>
                                            <!-- Pushed to remote: accent colour -->
                                            <Path Data="M4 14.899A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 2.5 8.242M12 12v9M16 16l-4-4-4 4"
                                                  Stroke="{StaticResource AppAccentBrush}"
                                                  StrokeThickness="1.5"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  Width="12" Height="12" Stretch="Uniform"
                                                  VerticalAlignment="Center"
                                                  Visibility="{x:Bind IsIconHighlighted, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            <!-- Not pushed / no remote: secondary colour -->
                                            <Path Data="M4 14.899A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 2.5 8.242M12 12v9M16 16l-4-4-4 4"
                                                  Stroke="{StaticResource AppTextSecondaryBrush}"
                                                  StrokeThickness="1.5"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  Width="12" Height="12" Stretch="Uniform"
                                                  VerticalAlignment="Center"
                                                  Visibility="{x:Bind IsIconHighlighted, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Button>
                            <Border Height="1" Margin="0,2,0,2"
                                    Background="{StaticResource AppDividerBrush}"
                                    Visibility="{x:Bind ShowSeparator, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Divider above push section -->
        <Border Height="1" Margin="0,4,0,2"
                Background="{StaticResource AppDividerBrush}"
                Visibility="{x:Bind Commits.HasCommits, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- Push error -->
        <TextBlock Text="{x:Bind Commits.PushError, Mode=OneWay}"
                   FontSize="11"
                   Foreground="#E5574B"
                   TextWrapping="Wrap"
                   Margin="4,4,4,0"
                   Visibility="{x:Bind Commits.HasPushError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- Push button -->
        <Button Command="{x:Bind Commits.PushCommand}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                Padding="4,4,4,4"
                Margin="0,4,0,0"
                Visibility="{x:Bind Commits.HasCommits, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <TextBlock Text="{x:Bind Commits.PushLabel, Mode=OneWay}"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Visibility="{x:Bind Commits.IsPushing, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                <ProgressRing Width="16" Height="16"
                              IsActive="{x:Bind Commits.IsPushing, Mode=OneWay}"
                              Visibility="{x:Bind Commits.IsPushing, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </Button>

    </StackPanel>
</UserControl>
