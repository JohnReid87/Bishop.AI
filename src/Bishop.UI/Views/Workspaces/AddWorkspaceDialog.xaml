<ContentDialog
    x:Class="Bishop.UI.Views.Workspaces.AddWorkspaceDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Add Workspace"
    PrimaryButtonText="Add"
    CloseButtonText="Cancel"
    DefaultButton="Primary">
    <ContentDialog.Resources>
        <SolidColorBrush x:Key="ContentDialogBackground" Color="#14141A"/>
    </ContentDialog.Resources>
    <StackPanel Spacing="12" MinWidth="320">
        <StackPanel Spacing="4">
            <TextBlock Text="Mode" Style="{StaticResource CaptionTextBlockStyle}"/>
            <StackPanel Orientation="Horizontal" Spacing="16">
                <RadioButton x:Name="PickExistingRadio"
                             Content="Pick existing folder"
                             IsChecked="{x:Bind ViewModel.IsPickExisting, Mode=TwoWay}"
                             GroupName="Mode"/>
                <RadioButton Content="Create new (git init)"
                             IsChecked="{x:Bind ViewModel.IsPickExisting, Mode=TwoWay, Converter={StaticResource BoolNegationConverter}}"
                             GroupName="Mode"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock Text="Name" Style="{StaticResource CaptionTextBlockStyle}"/>
            <TextBox PlaceholderText="e.g. My Project"
                     Text="{x:Bind ViewModel.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>

        <StackPanel Spacing="4"
                    Visibility="{x:Bind ViewModel.IsPickExisting, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="Folder" Style="{StaticResource CaptionTextBlockStyle}"/>
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         PlaceholderText="C:\code\my-project"
                         Text="{x:Bind ViewModel.FolderPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Column="1" Content="Browse…" Click="BrowseExistingButton_Click"/>
            </Grid>
        </StackPanel>

        <StackPanel Spacing="4"
                    Visibility="{x:Bind ViewModel.IsPickExisting, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <TextBlock Text="Parent folder" Style="{StaticResource CaptionTextBlockStyle}"/>
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         PlaceholderText="C:\code"
                         Text="{x:Bind ViewModel.ParentFolderPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Column="1" Content="Browse…" Click="BrowseParentButton_Click"/>
            </Grid>
            <TextBlock Text="New folder name" Style="{StaticResource CaptionTextBlockStyle}" Margin="0,8,0,0"/>
            <TextBox PlaceholderText="my-project"
                     Text="{x:Bind ViewModel.NewFolderName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock Text="{x:Bind ViewModel.CollisionError, Mode=OneWay}"
                       Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                       TextWrapping="Wrap"
                       Visibility="{x:Bind ViewModel.HasCollision, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
        </StackPanel>
    </StackPanel>
</ContentDialog>
