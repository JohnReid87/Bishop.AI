<ContentDialog
    x:Class="Bishop.UI.Views.PushLaneToGitHubDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Push to GitHub"
    PrimaryButtonText="Push"
    CloseButtonText="Close"
    DefaultButton="Close">
    <ContentDialog.Resources>
        <SolidColorBrush x:Key="ContentDialogBackground" Color="#141414"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"
            xmlns:converters="using:Bishop.UI.Converters"/>
    </ContentDialog.Resources>
    <StackPanel Spacing="12" MinWidth="360">
        <TextBlock Text="{x:Bind ViewModel.PreviewSummary}"
                   Style="{StaticResource CaptionTextBlockStyle}"/>
        <StackPanel Spacing="4"
                    Visibility="{x:Bind ViewModel.HasWillPush, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="Will push" Style="{StaticResource CaptionTextBlockStyle}"/>
            <ListView ItemsSource="{x:Bind ViewModel.WillPushItems}"
                      MaxHeight="200"
                      SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <TextBlock Text="{x:Bind}" TextWrapping="Wrap" Padding="0,2"/>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
        <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                      Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
        <TextBlock Text="{x:Bind ViewModel.ResultSummary, Mode=OneWay}"
                   Style="{StaticResource CaptionTextBlockStyle}"
                   Visibility="{x:Bind ViewModel.HasResults, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
    </StackPanel>
</ContentDialog>
