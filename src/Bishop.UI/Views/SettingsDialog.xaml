<ContentDialog
    x:Class="Bishop.UI.Views.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Bishop.UI.Views">
    <ContentDialog.Resources>
        <SolidColorBrush x:Key="ContentDialogBackground" Color="#14141A"/>
        <x:Double x:Key="ContentDialogMinWidth">560</x:Double>
        <x:Double x:Key="ContentDialogMaxWidth">560</x:Double>
        <x:Double x:Key="ContentDialogMinHeight">560</x:Double>
        <x:Double x:Key="ContentDialogMaxHeight">560</x:Double>
        <Thickness x:Key="ContentDialogPadding">0</Thickness>
    </ContentDialog.Resources>

    <StackPanel Spacing="0" MinWidth="560" MaxWidth="560" MinHeight="560" MaxHeight="560" Padding="24,12,24,12">

        <!-- Header: Settings label | X -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Settings"
                       Style="{StaticResource BodyStrongTextBlockStyle}"
                       Foreground="{StaticResource AppTextSecondaryBrush}"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1"
                    Style="{StaticResource SubtleIconButtonStyle}"
                    ToolTipService.ToolTip="Close"
                    Click="CloseDialog_Click"
                    VerticalAlignment="Center">
                <FontIcon Glyph="&#xE8BB;" FontSize="12" Foreground="{StaticResource AppTextPrimaryBrush}"/>
            </Button>
        </Grid>

        <!-- Divider: header / body -->
        <Border Height="1" Background="{StaticResource AppDividerBrush}" Margin="0,0,0,12"/>

        <TabView IsAddTabButtonVisible="False"
                 CanDragTabs="False"
                 CanReorderTabs="False"
                 HorizontalAlignment="Stretch">

            <TabViewItem Header="General" IsClosable="False">
                <TabViewItem.Content>
                    <StackPanel Spacing="0" Padding="0,8,0,4" HorizontalAlignment="Stretch">
                        <Border BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="0,0,0,1" Padding="0,4,0,8">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Version"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.AppVersion}"
                                           FontFamily="Cascadia Mono, Consolas, Courier New"/>
                            </StackPanel>
                        </Border>
                        <Border BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="0,0,0,1" Padding="0,8,0,8">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Database"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.DbPath}"
                                           FontFamily="Cascadia Mono, Consolas, Courier New"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Padding="0,8,0,4">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Build"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.BuildConfiguration}"
                                           FontFamily="Cascadia Mono, Consolas, Courier New"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </TabViewItem.Content>
            </TabViewItem>

            <TabViewItem Header="Workspaces" IsClosable="False">
                <TabViewItem.Content>
                    <local:ManageWorkspacesControl Padding="0,8,0,0"/>
                </TabViewItem.Content>
            </TabViewItem>

            <TabViewItem Header="Skills" IsClosable="False">
                <TabViewItem.Content>
                    <ScrollViewer Padding="0,8,0,4" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="SkillsPanel" Spacing="2" HorizontalAlignment="Stretch"/>
                    </ScrollViewer>
                </TabViewItem.Content>
            </TabViewItem>

        </TabView>
    </StackPanel>
</ContentDialog>
