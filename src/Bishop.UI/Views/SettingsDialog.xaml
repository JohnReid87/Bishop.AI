<ContentDialog
    x:Class="Bishop.UI.Views.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Bishop.UI.Views"
    Title="Settings"
    CloseButtonText="Close">
    <ContentDialog.Resources>
        <SolidColorBrush x:Key="ContentDialogBackground" Color="#14141A"/>
        <x:Double x:Key="ContentDialogMinWidth">480</x:Double>
        <x:Double x:Key="ContentDialogMaxWidth">600</x:Double>
    </ContentDialog.Resources>

    <TabView IsAddTabButtonVisible="False"
             CanDragTabs="False"
             CanReorderTabs="False"
             HorizontalAlignment="Stretch">

        <TabViewItem Header="General" IsClosable="False">
            <TabViewItem.Content>
                <StackPanel Spacing="12" Padding="0,8,0,4">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Version"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{StaticResource AppTextSecondaryBrush}"/>
                        <TextBlock Text="{x:Bind ViewModel.AppVersion}"
                                   FontFamily="Cascadia Mono, Consolas, Courier New"/>
                    </StackPanel>
                    <StackPanel Spacing="2">
                        <TextBlock Text="Database"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{StaticResource AppTextSecondaryBrush}"/>
                        <TextBlock Text="{x:Bind ViewModel.DbPath}"
                                   FontFamily="Cascadia Mono, Consolas, Courier New"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Spacing="2">
                        <TextBlock Text="Build"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{StaticResource AppTextSecondaryBrush}"/>
                        <TextBlock Text="{x:Bind ViewModel.BuildConfiguration}"
                                   FontFamily="Cascadia Mono, Consolas, Courier New"/>
                    </StackPanel>
                </StackPanel>
            </TabViewItem.Content>
        </TabViewItem>

        <TabViewItem Header="Workspaces" IsClosable="False">
            <TabViewItem.Content>
                <local:ManageWorkspacesControl Padding="0,8,0,0"/>
            </TabViewItem.Content>
        </TabViewItem>

        <TabViewItem Header="Skills" IsClosable="False">
            <TabViewItem.Content>
                <TextBlock Text="Coming soon"
                           Foreground="{StaticResource AppTextTertiaryBrush}"
                           FontStyle="Italic"
                           Padding="0,8,0,0"/>
            </TabViewItem.Content>
        </TabViewItem>

    </TabView>
</ContentDialog>
