<ContentDialog
    x:Class="Bishop.UI.Views.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Bishop.UI.Views">
    <ContentDialog.Resources>
        <SolidColorBrush x:Key="ContentDialogBackground" Color="#14141A"/>
    </ContentDialog.Resources>

    <StackPanel Spacing="0" MinWidth="560" MaxWidth="560" MinHeight="560" MaxHeight="560">

        <!-- Header: Settings label | X -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Settings"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{StaticResource AppTextTertiaryBrush}"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1"
                    Style="{StaticResource DateTimePickerFlyoutButtonStyle}"
                    ToolTipService.ToolTip="Close"
                    Click="CloseDialog_Click"
                    VerticalAlignment="Center">
                <FontIcon Glyph="&#xE8BB;" FontSize="12"/>
            </Button>
        </Grid>

        <!-- Divider: header / body -->
        <Border Height="1" Background="{StaticResource AppDividerBrush}" Margin="0,0,0,12"/>

        <TabView IsAddTabButtonVisible="False"
                 CanDragTabs="False"
                 CanReorderTabs="False"
                 HorizontalAlignment="Stretch">

            <TabViewItem Header="General" IsClosable="False">
                <TabViewItem.Content>
                    <StackPanel Spacing="12" Padding="0,8,0,4">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Version"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{StaticResource AppTextSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.AppVersion}"
                                       FontFamily="Cascadia Mono, Consolas, Courier New"/>
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Database"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{StaticResource AppTextSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.DbPath}"
                                       FontFamily="Cascadia Mono, Consolas, Courier New"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Build"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{StaticResource AppTextSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.BuildConfiguration}"
                                       FontFamily="Cascadia Mono, Consolas, Courier New"/>
                        </StackPanel>
                    </StackPanel>
                </TabViewItem.Content>
            </TabViewItem>

            <TabViewItem Header="Workspaces" IsClosable="False">
                <TabViewItem.Content>
                    <local:ManageWorkspacesControl Padding="0,8,0,0"/>
                </TabViewItem.Content>
            </TabViewItem>

            <TabViewItem Header="Skills" IsClosable="False">
                <TabViewItem.Content>
                    <ScrollViewer Padding="0,8,0,4" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="SkillsPanel" Spacing="2"/>
                    </ScrollViewer>
                </TabViewItem.Content>
            </TabViewItem>

        </TabView>
    </StackPanel>
</ContentDialog>
