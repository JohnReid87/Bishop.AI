<Window
    x:Class="Bishop.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Bishop.ViewModels.Workspaces"
    xmlns:vmErrors="using:Bishop.ViewModels.Errors"
    xmlns:cnv="using:Bishop.UI.Converters"
    Title="Bishop.AI">
    <Grid x:Name="RootGrid" PreviewKeyDown="RootGrid_PreviewKeyDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom title bar drag region -->
        <Grid x:Name="AppTitleBar" Grid.Row="0"
              Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="138"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"
                       FontSize="12"
                       FontFamily="Cascadia Mono, Consolas, Courier New">
                <Run Text="bishop" Foreground="{StaticResource AppTextPrimaryBrush}"/><Run Text=".ai" Foreground="{StaticResource AppAccentBrush}"/>
            </TextBlock>

            <!-- Cat mode toggle: paw button (off state) -->
            <Button Grid.Column="1"
                    Width="40" Height="32"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                    Visibility="{x:Bind cnv:XamlConvert.ToVisInverse(ViewModel.IsCatModeActive), Mode=OneWay}"
                    Command="{x:Bind ViewModel.ToggleCatModeCommand}"
                    ToolTipService.ToolTip="Pause keyboard input (cat mode)">
                <Path Data="{StaticResource IconPawPrintData}"
                      Stroke="{StaticResource AppTextSecondaryBrush}"
                      StrokeThickness="1.5"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                      Width="16" Height="16" Stretch="Uniform"/>
            </Button>

            <!-- Cat mode toggle: paw button (on state) -->
            <Button Grid.Column="1"
                    Width="40" Height="32"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                    Visibility="{x:Bind cnv:XamlConvert.ToVis(ViewModel.IsCatModeActive), Mode=OneWay}"
                    Command="{x:Bind ViewModel.ToggleCatModeCommand}"
                    ToolTipService.ToolTip="Resume keyboard input (cat mode active)">
                <Path Data="{StaticResource IconPawPrintData}"
                      Fill="{StaticResource AppTextPrimaryBrush}"
                      Stroke="{StaticResource AppTextPrimaryBrush}"
                      StrokeThickness="1.5"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                      Width="16" Height="16" Stretch="Uniform"/>
            </Button>
        </Grid>

        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            PaneDisplayMode="Top"
            IsSettingsVisible="False"
            IsBackButtonVisible="Collapsed"
            IsTitleBarAutoPaddingEnabled="False">

            <NavigationView.Resources>
                <!-- Trim the top pane from its 48px default so the workspace strip reads
                     tighter; items and the active-border marker stretch to this height. -->
                <x:Double x:Key="NavigationViewTopPaneHeight">38</x:Double>
            </NavigationView.Resources>

            <NavigationView.PaneCustomContent>
                <Grid Margin="4,0,4,0" HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Add button pinned at the fixed left end -->
                    <Button Grid.Column="0"
                            x:Name="AddWorkspaceButton"
                            VerticalAlignment="Center"
                            MinHeight="0" MinWidth="0" Padding="8,3"
                            Style="{StaticResource SubtleIconButtonStyle}"
                            Click="AddWorkspaceButton_Click"
                            ToolTipService.ToolTip="Add workspace">
                        <FontIcon Glyph="&#xE710;" FontSize="14" Foreground="{StaticResource AppTextPrimaryBrush}"/>
                    </Button>

                    <!-- Empty state -->
                    <TextBlock Grid.Column="1"
                               x:Name="EmptyStateText"
                               Text="No workspaces yet"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"/>

                    <!-- Horizontal, sideways-scrolling strip of full-name workspace chips -->
                    <ScrollViewer Grid.Column="1"
                                  VerticalScrollBarVisibility="Disabled"
                                  HorizontalScrollBarVisibility="Auto"
                                  HorizontalScrollMode="Enabled">
                        <ListView x:Name="WorkspacesListView"
                                  ItemsSource="{x:Bind ViewModel.Workspaces}"
                                  SelectedItem="{x:Bind ViewModel.SelectedWorkspace, Mode=TwoWay}"
                                  CanDragItems="True"
                                  AllowDrop="True"
                                  SelectionMode="Single"
                                  DragItemsStarting="WorkspaceDragItemsStarting"
                                  DropCompleted="WorkspacesDragCompleted"
                                  DragOver="WorkspacesDragOver"
                                  Drop="WorkspacesDrop">
                            <ListView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsStackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ListView.ItemsPanel>
                            <ListView.Resources>
                                <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="#20FFFFFF"/>
                                <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="#30FFFFFF"/>
                                <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed" Color="#40FFFFFF"/>
                                <!-- Suppress the default edge selection bar; the active item is marked
                                     by a full-height green border in the item template instead. -->
                                <SolidColorBrush x:Key="ListViewItemSelectionIndicatorBrush" Color="Transparent"/>
                                <SolidColorBrush x:Key="ListViewItemSelectionIndicatorPointerOverBrush" Color="Transparent"/>
                                <SolidColorBrush x:Key="ListViewItemSelectionIndicatorPressedBrush" Color="Transparent"/>
                            </ListView.Resources>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="vm:WorkspaceItemViewModel">
                                    <Grid RightTapped="WorkspaceItem_RightTapped"
                                          VerticalAlignment="Center"
                                          Opacity="{x:Bind cnv:XamlConvert.ToDimOpacity(IsHidden), Mode=OneWay}">
                                        <Grid Padding="12,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{x:Bind Name, Mode=OneWay}"
                                                       VerticalAlignment="Center"/>
                                            <FontIcon Grid.Column="1"
                                                      Glyph="&#xE7BA;"
                                                      FontSize="12"
                                                      Foreground="{StaticResource BrushError}"
                                                      Margin="4,0,0,0"
                                                      VerticalAlignment="Center"
                                                      Visibility="{x:Bind cnv:XamlConvert.ToVis(IsPathMissing), Mode=OneWay}"/>
                                        </Grid>

                                        <!-- Active-workspace marker: green underline beneath the name,
                                             inset so its ends sit within the pill's rounded corners. -->
                                        <Rectangle Height="2"
                                                   Fill="#00FF41"
                                                   Margin="6,0,6,0"
                                                   VerticalAlignment="Bottom"
                                                   HorizontalAlignment="Stretch"
                                                   IsHitTestVisible="False"
                                                   Visibility="{x:Bind cnv:XamlConvert.ToVis(IsSelected), Mode=OneWay}"/>

                                        <FlyoutBase.AttachedFlyout>
                                            <MenuFlyout>
                                                <MenuFlyoutItem Text="Rename" Click="RenameWorkspace_Click">
                                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8AC;"/></MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutItem Text="Repath…" Click="RepathWorkspace_Click">
                                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8DA;"/></MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutItem Text="Hide" Click="HideWorkspace_Click"
                                                                Visibility="{x:Bind cnv:XamlConvert.ToVisInverse(IsHidden), Mode=OneWay}">
                                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xED1A;"/></MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutItem Text="Unhide" Click="UnhideWorkspace_Click"
                                                                Visibility="{x:Bind cnv:XamlConvert.ToVis(IsHidden), Mode=OneWay}">
                                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE7B3;"/></MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutSeparator/>
                                                <MenuFlyoutItem Text="Remove" Click="DeleteWorkspace_Click">
                                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74D;"/></MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                            </MenuFlyout>
                                        </FlyoutBase.AttachedFlyout>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,0,4,0"/>
                                    <Setter Property="MinHeight" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>
                    </ScrollViewer>

                    <!-- Show hidden toggle at the strip's right end -->
                    <ToggleButton Grid.Column="2"
                                  x:Name="ShowHiddenToggle"
                                  VerticalAlignment="Center"
                                  Margin="4,0,0,0"
                                  MinHeight="0" MinWidth="0" Padding="8,3"
                                  IsChecked="{x:Bind ViewModel.ShowHidden, Mode=TwoWay}"
                                  ToolTipService.ToolTip="Show hidden workspaces">
                        <FontIcon Glyph="&#xE890;" FontSize="14"/>
                    </ToggleButton>
                </Grid>
            </NavigationView.PaneCustomContent>

            <NavigationView.PaneFooter>
                <Grid VerticalAlignment="Center">
                    <Grid.Resources>
                        <!-- Compact icon-only footer buttons: shed the default 32px MinHeight
                             and chunky padding so they sit tight in the trimmed strip. -->
                        <Style x:Key="StripFooterButtonStyle" TargetType="Button"
                               BasedOn="{StaticResource DateTimePickerFlyoutButtonStyle}">
                            <Setter Property="MinHeight" Value="0"/>
                            <Setter Property="MinWidth" Value="0"/>
                            <Setter Property="Padding" Value="8,3"/>
                        </Style>
                    </Grid.Resources>
                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="4,0,8,0">
                        <!-- Life button -->
                        <Button x:Name="LifeButton"
                                Style="{StaticResource StripFooterButtonStyle}"
                                Click="LifeButton_Click"
                                ToolTipService.ToolTip="Life">
                            <FontIcon Glyph="&#xE00B;" FontSize="14" VerticalAlignment="Center"/>
                        </Button>
                        <!-- Scripts button -->
                        <Button Style="{StaticResource StripFooterButtonStyle}"
                                Click="ScriptsButton_Click"
                                ToolTipService.ToolTip="Scripts">
                            <FontIcon Glyph="&#xE756;" FontSize="14" VerticalAlignment="Center"/>
                        </Button>
                        <!-- Bishop tools button -->
                        <Button Style="{StaticResource StripFooterButtonStyle}"
                                Click="SettingsButton_Click"
                                ToolTipService.ToolTip="Bishop tools">
                            <FontIcon Glyph="&#xE713;" FontSize="14" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                    <TeachingTip x:Name="LifeLaunchErrorTip"
                                 Title="Couldn't launch Life"
                                 PreferredPlacement="Bottom"
                                 IsLightDismissEnabled="True"/>
                </Grid>
            </NavigationView.PaneFooter>

            <Grid Background="{StaticResource AppBackgroundBrush}">
                <Frame x:Name="ContentFrame"/>

                <!-- Error notification stack -->
                <ItemsControl ItemsSource="{x:Bind ViewModel.Notifications, Mode=OneWay}"
                              VerticalAlignment="Top"
                              Margin="8,8,8,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vmErrors:ErrorNotificationViewModel">
                            <InfoBar IsOpen="{x:Bind IsOpen, Mode=TwoWay}"
                                     IsClosable="True"
                                     Severity="Error"
                                     Title="{x:Bind Title, Mode=OneWay}"
                                     Message="{x:Bind Message, Mode=OneWay}"
                                     Margin="0,0,0,4">
                                <InfoBar.ActionButton>
                                    <Button Content="Show details"
                                            Command="{x:Bind ShowDetailsCommand}"/>
                                </InfoBar.ActionButton>
                            </InfoBar>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Cat mode tint: subtle dark overlay across the whole content area -->
                <Border IsHitTestVisible="False"
                        Background="#80000000"
                        Visibility="{x:Bind cnv:XamlConvert.ToVis(ViewModel.IsCatModeActive), Mode=OneWay}"/>

                <!-- Cat mode mark: centered cat illustration so the state is visible from across the room -->
                <Viewbox IsHitTestVisible="False"
                         MaxWidth="420" MaxHeight="420"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Visibility="{x:Bind cnv:XamlConvert.ToVis(ViewModel.IsCatModeActive), Mode=OneWay}">
                    <Path Data="{StaticResource IconCatModePanelData}"
                          Fill="#CCE8E8E8"
                          Stretch="Uniform"/>
                </Viewbox>

                <!-- Empty state: centered brand mark + wordmark + CTAs -->
                <Grid x:Name="WorkspaceEmptyState"
                      Visibility="{x:Bind cnv:XamlConvert.ToVis(ViewModel.IsContentEmpty), Mode=OneWay}">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="32">
                        <!-- Large logo mark, recreated from 01-logo-mark.svg -->
                        <Viewbox Width="160" Height="192" HorizontalAlignment="Center">
                            <Canvas Width="200" Height="240">
                                <Rectangle Canvas.Left="15" Canvas.Top="10"
                                           Width="22" Height="220"
                                           RadiusX="3" RadiusY="3"
                                           Fill="#E8E8E8"/>
                                <Ellipse Canvas.Left="35" Canvas.Top="90"
                                         Width="140" Height="140"
                                         Stroke="#E8E8E8"
                                         StrokeThickness="22"/>
                                <Rectangle Canvas.Left="95" Canvas.Top="82"
                                           Width="20" Height="148"
                                           RadiusX="3" RadiusY="3"
                                           Fill="#888888"/>
                                <Ellipse Canvas.Left="93" Canvas.Top="48"
                                         Width="24" Height="24"
                                         Fill="{StaticResource AppAccentBrush}"/>
                            </Canvas>
                        </Viewbox>

                        <!-- Wordmark: matches 02-wordmark-horizontal.svg text -->
                        <TextBlock HorizontalAlignment="Center"
                                   FontFamily="Cascadia Mono, Consolas, Courier New"
                                   FontSize="40"
                                   FontWeight="Medium">
                            <Run Text="bishop" Foreground="{StaticResource AppTextPrimaryBrush}"/><Run Text=".ai" Foreground="{StaticResource AppAccentBrush}"/>
                        </TextBlock>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Spacing="12"
                                    Margin="0,16,0,0">
                            <Button x:Name="CreateWorkspaceCta"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Click="CreateWorkspaceCta_Click"
                                    Content="Create your first workspace"/>
                            <Button x:Name="OpenWorkspaceCta"
                                    Click="OpenWorkspaceCta_Click"
                                    Content="Open an existing workspace"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>
        </NavigationView>
    </Grid>
</Window>
