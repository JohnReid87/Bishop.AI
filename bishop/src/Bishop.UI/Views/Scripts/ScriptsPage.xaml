<Page
    x:Class="Bishop.UI.Views.Scripts.ScriptsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Bishop.ViewModels.Scripts">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Orientation="Horizontal"
                    Spacing="8"
                    Padding="12,8,12,8"
                    BorderBrush="{ThemeResource AppDividerBrush}"
                    BorderThickness="0,0,0,1">
            <Button Content="Open Folder"
                    Command="{x:Bind ViewModel.OpenFolderCommand}"/>
            <Button Content="Create new script"
                    Command="{x:Bind ViewModel.CreateNewScriptCommand}"/>
            <Button Content="Refresh"
                    Command="{x:Bind ViewModel.LoadScriptsCommand}"/>
        </StackPanel>

        <!-- Script list -->
        <ListView Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.Scripts, Mode=OneWay}"
                  SelectionMode="None">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="12,6"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:ScriptItemViewModel">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{x:Bind Name}"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   FontFamily="Cascadia Mono, Consolas, Courier New"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBox Grid.Column="1"
                                 Text="{x:Bind Args, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="args"
                                 FontSize="12"/>
                        <Button Grid.Column="2"
                                Content="Run"
                                Click="RunButton_Click"/>
                        <Button Grid.Column="3"
                                Content="Edit"
                                Command="{x:Bind EditCommand}"/>
                        <Button Grid.Column="4"
                                Content="Delete"
                                Click="DeleteButton_Click"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
