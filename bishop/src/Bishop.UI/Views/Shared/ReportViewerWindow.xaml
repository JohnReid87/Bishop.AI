<Window
    x:Class="Bishop.UI.Views.Shared.ReportViewerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Report">
    <Grid Background="{StaticResource AppSurfaceBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Grid.Row="0"
              Background="{StaticResource AppSurfaceBrush}">
            <TextBlock VerticalAlignment="Center"
                       Margin="12,0,0,0"
                       FontSize="12"
                       FontFamily="Cascadia Mono, Consolas, Courier New"
                       Foreground="{StaticResource AppTextPrimaryBrush}"
                       Text="Report"/>
        </Grid>

        <WebView2 x:Name="ReportWebView" Grid.Row="1"/>
    </Grid>
</Window>
