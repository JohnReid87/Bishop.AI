<ContentDialog
    x:Class="Bishop.UI.Views.Settings.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:workspaces="using:Bishop.UI.Views.Workspaces">
    <ContentDialog.Resources>
        <StaticResource x:Key="ContentDialogBackground" ResourceKey="AppSurfaceElevatedBrush"/>
        <x:Double x:Key="ContentDialogMinWidth">560</x:Double>
        <x:Double x:Key="ContentDialogMaxWidth">560</x:Double>
        <x:Double x:Key="ContentDialogMinHeight">560</x:Double>
        <x:Double x:Key="ContentDialogMaxHeight">560</x:Double>
        <Thickness x:Key="ContentDialogPadding">0</Thickness>
    </ContentDialog.Resources>

    <Grid MinWidth="560" MaxWidth="560" MinHeight="560" MaxHeight="560" Translation="0,0,32">
        <Grid.Shadow>
            <ThemeShadow/>
        </Grid.Shadow>
    <StackPanel Spacing="0" Padding="24,12,24,12">

        <!-- Header: Settings label | X -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Settings"
                       Style="{StaticResource BodyStrongTextBlockStyle}"
                       Foreground="{StaticResource AppTextSecondaryBrush}"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1"
                    Style="{StaticResource SubtleIconButtonStyle}"
                    ToolTipService.ToolTip="Close"
                    Click="CloseDialog_Click"
                    VerticalAlignment="Center">
                <FontIcon Glyph="&#xE8BB;" FontSize="12" Foreground="{StaticResource AppTextPrimaryBrush}"/>
            </Button>
        </Grid>

        <!-- Divider: header / body -->
        <Border Height="1" Background="{StaticResource AppDividerBrush}" Margin="0,0,0,12"/>

        <StackPanel Orientation="Horizontal"
                    Spacing="6"
                    Margin="0,0,0,8">
            <RadioButton x:Name="GeneralRadio"
                         Style="{StaticResource SegmentedRadioButtonStyle}"
                         GroupName="SettingsSection"
                         Tag="General"
                         IsChecked="True"
                         Checked="SettingsSectionRadio_Checked">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE713;" FontSize="14" VerticalAlignment="Center"/>
                    <TextBlock Text="General" VerticalAlignment="Center"/>
                </StackPanel>
            </RadioButton>
            <RadioButton x:Name="WorkspacesRadio"
                         Style="{StaticResource SegmentedRadioButtonStyle}"
                         GroupName="SettingsSection"
                         Tag="Workspaces"
                         Checked="SettingsSectionRadio_Checked">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE838;" FontSize="14" VerticalAlignment="Center"/>
                    <TextBlock Text="Workspaces" VerticalAlignment="Center"/>
                </StackPanel>
            </RadioButton>
            <RadioButton x:Name="SkillsRadio"
                         Style="{StaticResource SegmentedRadioButtonStyle}"
                         GroupName="SettingsSection"
                         Tag="Skills"
                         Checked="SettingsSectionRadio_Checked">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xEBD2;" FontSize="14" VerticalAlignment="Center"/>
                    <TextBlock Text="Skills" VerticalAlignment="Center"/>
                </StackPanel>
            </RadioButton>
        </StackPanel>

        <Grid>
            <StackPanel x:Name="GeneralContent" Spacing="0" Padding="0,8,0,4" HorizontalAlignment="Stretch">
                        <Border BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="0,0,0,1" Padding="0,4,0,8">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Version"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.AppVersion}"
                                           FontFamily="Cascadia Mono, Consolas, Courier New"/>
                            </StackPanel>
                        </Border>
                        <Border BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="0,0,0,1" Padding="0,8,0,8">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Database"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{x:Bind ViewModel.DbPath}"
                                               FontFamily="Cascadia Mono, Consolas, Courier New"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1"
                                            Style="{StaticResource SubtleIconButtonStyle}"
                                            ToolTipService.ToolTip="Copy DB path"
                                            Click="CopyDbPathButton_Click"
                                            VerticalAlignment="Center"
                                            Margin="8,0,0,0">
                                        <FontIcon Glyph="&#xE8C8;" FontSize="12" Foreground="{StaticResource AppTextPrimaryBrush}"/>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border Padding="0,8,0,4">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Build"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.BuildConfiguration}"
                                           FontFamily="Cascadia Mono, Consolas, Courier New"/>
                            </StackPanel>
                        </Border>
            </StackPanel>

            <workspaces:ManageWorkspacesControl x:Name="WorkspacesContent"
                                                Padding="0,8,0,0"
                                                Visibility="Collapsed"/>

            <ScrollViewer x:Name="SkillsContent"
                          Padding="0,8,0,4"
                          VerticalScrollBarVisibility="Auto"
                          Visibility="Collapsed">
                <StackPanel x:Name="SkillsPanel" Spacing="2" HorizontalAlignment="Stretch"/>
            </ScrollViewer>
        </Grid>
    </StackPanel>

    <InfoBar x:Name="CopiedBar"
             VerticalAlignment="Bottom"
             Margin="16,0,16,16"
             IsOpen="False"
             IsClosable="False"
             Severity="Success"
             Title="Copied to clipboard"/>
    </Grid>
</ContentDialog>
